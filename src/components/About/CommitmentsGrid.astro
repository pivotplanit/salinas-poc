---
import { commitments } from "../../lib/about-data";
import IconRenderer from "../IconRenderer.astro";
---

<section class="commitments-section">
  <div class="container">
    <h2>Our Commitments to Responsible Tourism</h2>

    <div class="commitments-box">
      <div class="commitments-list">
        {
          commitments.map((item) => (
            <div class="commitment-item">
              <IconRenderer icon="CheckCircle" size={24} />
              <span>{item.title}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .commitments-section {
    padding: 4rem 1rem;
    background: #f0f7e64d;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
    margin: 0 0 3rem 0;
    text-align: center;
  }

  .commitments-box {
    position: relative;
    border: 1px solid #6b9b371a;
    max-width: 900px;
    margin: 0 auto;
    border-radius: 8px;
    padding: 3rem 2.5rem;
    background: white;
    box-shadow: 0px 0px 0px 0px #00000000;
    box-shadow: 0px 0px 0px 0px #00000000;
    box-shadow: 0px 1px 2px 0px #0000000d;
  }

  .commitments-label {
    position: absolute;
    top: -12px;
    left: 1.5rem;
    background: white;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    color: #9ca3af;
    font-weight: 500;
    border: 1px solid #e5e7eb;
    border-radius: 3px;
    padding: 0.25rem 0.75rem;
  }

  .commitments-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .commitment-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.125rem;
    color: #374151;
    font-weight: 500;
  }

  .commitment-item :global(.icon) {
    flex-shrink: 0;
    color: #6B9B37;
  }

  @media (max-width: 768px) {
    .commitments-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
    }

    .commitments-box {
      padding: 2rem 1.5rem;
    }

    .commitment-item {
      font-size: 1rem;
      gap: 0.75rem;
    }

    .checkmark-icon {
      width: 20px;
      height: 20px;
    }
  }
</style>
