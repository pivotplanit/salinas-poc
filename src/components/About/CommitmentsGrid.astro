---
import { commitments } from "../../lib/about-data";
---

<section class="commitments-section">
  <div class="container">
    <h2>Our Commitments</h2>
    <p class="section-subtitle">Values that guide every decision</p>
    
    <div class="commitments-grid">
      {commitments.map((item) => (
        <div class="commitment-card">
          <div class="commitment-emoji">{item.emoji}</div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .commitments-section {
    padding: 4rem 1rem;
    background: #f5f5f5;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1.1rem;
    margin: 0 0 3rem 0;
  }

  .commitments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .commitment-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    border-left: 4px solid #2D5016;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 300ms ease;
  }

  .commitment-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
    border-left-color: #A8D5BA;
  }

  .commitment-emoji {
    font-size: 3rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .commitment-card h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2rem;
    color: #2D5016;
    font-weight: 600;
  }

  .commitment-card p {
    margin: 0;
    color: #666;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .commitments-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 2rem;
    }

    .commitments-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .commitment-card {
      padding: 1.5rem;
    }

    .commitment-emoji {
      font-size: 2.5rem;
    }
  }
</style>
