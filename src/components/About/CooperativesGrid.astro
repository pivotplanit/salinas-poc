---
import { cooperatives } from "../../lib/about-data";
---

<section class="cooperatives-section">
  <div class="container">
    <h2>Partner Cooperatives</h2>

    <div class="cooperatives-grid">
      {cooperatives.map((coop) => (
        <div class="cooperative-card">
          <div class="cooperative-logo">
            <img src={coop.logo} alt={`${coop.name} logo`} width="120" height="120" loading="lazy" />
          </div>
          <h3>{coop.name}</h3>
          <p class="cooperative-category">{coop.category}</p>
          <a href={coop.url} class="visit-link" target="_blank" rel="noopener noreferrer">
            Visit &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cooperatives-section {
    padding: 4rem 1rem;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-dark, #1a1a1a);
    margin: 0 0 2rem 0;
  }

  .cooperatives-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .cooperative-card {
    background: white;
    border: 1px dashed #c8cdd3;
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
  }

  .cooperative-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .cooperative-logo img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    background: #e8ebef;
  }

  .cooperative-card h3 {
    margin: 0;
    font-size: 1.05rem;
    color: var(--text-dark, #1a1a1a);
    font-weight: 600;
  }

  .cooperative-category {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
  }

  .visit-link {
    display: inline-block;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-dark, #1a1a1a);
    text-decoration: none;
    font-weight: 500;
    transition: color 200ms ease;
  }

  .visit-link:hover {
    color: var(--primary, #2D5016);
  }

  @media (max-width: 1024px) {
    .cooperatives-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cooperatives-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 1.75rem;
    }

    .cooperatives-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .cooperatives-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

