---
import { cooperatives } from "../../lib/about-data";
import Button from "../Button.astro";
---

<section class="cooperatives-section">
  <div class="container">
    <h2>Partner Cooperatives</h2>
    <p class="section-subtitle">Supporting 10 active cooperatives across Ecuador</p>
    
    <div class="cooperatives-grid">
      {cooperatives.map((coop) => (
        <div class="cooperative-card">
          <div class="cooperative-logo">🏢</div>
          <h3>{coop.name}</h3>
          <p class="cooperative-category">{coop.category}</p>
          <p class="cooperative-description">{coop.description}</p>
          <Button 
            text="Visit" 
            href={`#${coop.name.toLowerCase()}`}
            variant="outline"
            size="sm"
            fullWidth
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cooperatives-section {
    padding: 4rem 1rem;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1.1rem;
    margin: 0 0 3rem 0;
  }

  .cooperatives-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .cooperative-card {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #e0e0e0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 300ms ease;
    text-align: center;
  }

  .cooperative-card:hover {
    border-color: #2D5016;
    box-shadow: 0 4px 12px rgba(45, 80, 22, 0.1);
    transform: translateY(-2px);
  }

  .cooperative-logo {
    font-size: 2.5rem;
    line-height: 1;
  }

  .cooperative-card h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #2D5016;
    font-weight: 600;
  }

  .cooperative-category {
    margin: 0;
    font-size: 0.85rem;
    color: #8B7355;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cooperative-description {
    margin: 0;
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
    flex: 1;
  }

  @media (max-width: 768px) {
    .cooperatives-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 2rem;
    }

    .cooperatives-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
    }

    .cooperative-card {
      padding: 1rem;
    }

    .cooperative-logo {
      font-size: 2rem;
    }

    .cooperative-card h3 {
      font-size: 1rem;
    }
  }
</style>
