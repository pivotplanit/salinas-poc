---
import { flavors } from "../../lib/about-data";
import IconRenderer from "../IconRenderer.astro";
---

<section class="flavors-section">
  <div class="section-container">
    <h2>Flavors of Salinas</h2>
    <p class="intro">
      The gastronomy of Salinas de Guaranda combines Andean tradition, artisan
      products, and strong community identity.
    </p>

    <div class="flavors-grid">
      {flavors.map((flavor) => (
        <div class="flavor-card">
          <div class="card-header">
            <IconRenderer icon="Utensils" size={22} />
            <h3>{flavor.title}</h3>
          </div>
          <p>{flavor.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .flavors-section {
    padding: 4rem 1rem;
    color: #fff;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary, #2b6cb0);
    margin: 0 0 1.5rem 0;
    text-align: center;
  }

  .intro {
    margin: 0 auto 3rem auto;
    max-width: 640px;
    text-align: center;
    color: #9ca3af;
    line-height: 1.6;
    font-size: 1rem;
  }

  .flavors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .flavor-card {
    background: #fff;
    color: #1f2937;
    border-left: 4px solid #D4A574;
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    color: #D4A574;
  }

  .flavor-card h3 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1f3a8a;
  }

  .flavor-card p {
    margin: 0;
    color: #6b7280;
    line-height: 1.5;
    font-size: 0.9rem;
    padding-left: 2rem;
  }

  @media (max-width: 768px) {
    .flavors-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 1.5rem;
    }

    .flavors-grid {
      grid-template-columns: 1fr;
    }

    .flavor-card p {
      padding-left: 0;
    }
  }
</style>
