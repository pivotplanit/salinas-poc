---
import { Image } from "astro:assets";
interface Slide {
  type: "image" | "video";
  src: string;
  alt: string;
  poster?: string;
}

interface Props {
  slides?: Slide[];
  title?: string;
  subtitle?: string;
}

const defaultSlides: Slide[] = [
  {
    type: "video",
    src: "https://assets.habitattraveltours.com/videos/salinas-about-hero.mp4",
    alt: "Ecuador tropical rainforest canopy",
  },
  {
    type: "image",
    src: "https://assets.habitattraveltours.com/images/salinas-grp-travelers-01.jpg",
    alt: "Ecuadorian highlands landscape",
  },
  {
    type: "video",
    src: "https://assets.habitattraveltours.com/videos/salinas-cross.mp4",
    alt: "Lush green countryside scenery",
    poster: "https://images.unsplash.com/photo-1594398901394-4e34939a02ee?w=1600&h=900&fit=crop",
  },
];

const {
  slides = defaultSlides,
  title = "Salinas de Guaranda",
  subtitle = "Where the Mountains Hold Magic and Community Creates Stories",
} = Astro.props;
---

<section class="hero-carousel-section">
  <div class="carousel-container">
    <div class="carousel-main">
      {
        slides.map((slide, index) => (
          <div
            class:list={['carousel-slide', { active: index === 0 }]}
            data-slide={index}
          >
            {slide.type === 'video' ? (
              <video
                class="slide-media"
                src={slide.src}
                poster={slide.poster}
                muted
                controls
                playsinline
                preload="metadata"
              />
            ) : (
              <Image
                class="slide-media"
                src={slide.src}
                alt={slide.alt}
                width={1600}
                height={900}
                loading={'eager'}
              />
            )}
          </div>
        ))
      }
    </div>

    {
      slides.length > 1 && (
        <>
          <button
            class="carousel-btn carousel-btn-prev"
            aria-label="Previous image"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="15 18 9 12 15 6" />
            </svg>
          </button>
          <button
            class="carousel-btn carousel-btn-next"
            aria-label="Next image"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </button>
        </>
      )
    }

    <div class="hero-overlay">
      {title && <h1 class="hero-title">{title}</h1>}
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      {
        slides.length > 1 && (
          <div class="hero-indicators">
            {slides.map((_, index) => (
              <button
                class:list={['hero-dot', { active: index === 0 }]}
                data-dot={index}
                aria-label={`Go to slide ${index + 1}`}
                aria-current={index === 0}
              />
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero-carousel-section {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 100vh;
    overflow: hidden;
    background: var(--medium-gray);
  }

  .carousel-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .carousel-main {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .carousel-slide {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-in-out;
    background: var(--medium-gray);
    z-index: 1;
  }

  .carousel-slide.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .slide-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom;
    display: block;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 300ms ease;
    backdrop-filter: blur(10px);
    z-index: 10;
  }

  .carousel-btn-prev {
    left: 2rem;
  }

  .carousel-btn-next {
    right: 2rem;
  }

  .carousel-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    border-color: white;
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-btn:active {
    transform: translateY(-50%) scale(0.95);
  }

  /* Bottom-centered overlay: title, subtitle, dots */
  .hero-overlay {
    position: absolute;
    bottom: 2rem;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1.5rem;
    z-index: 10;
    text-align: center;
    pointer-events: none;
  }

  .hero-title {
    margin: 0;
    color: white;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    text-wrap: balance;
  }

  .hero-subtitle {
    margin: 0;
    color: rgba(255, 255, 255, 0.95);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.5;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    text-wrap: balance;
  }

  .hero-indicators {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    pointer-events: auto;
  }

  .hero-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 300ms ease;
  }

  .hero-dot:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .hero-dot.active {
    background: white;
    width: 32px;
    border-radius: 5px;
  }

  @media (max-width: 768px) {
    .carousel-btn {
      width: 40px;
      height: 40px;
    }

    .carousel-btn-prev {
      left: 1rem;
    }

    .carousel-btn-next {
      right: 1rem;
    }

    .hero-overlay {
      bottom: 1.5rem;
      gap: 0.5rem;
    }

    .hero-title {
      font-size: 1.85rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .carousel-btn {
      width: 36px;
      height: 36px;
    }

    .hero-title {
      font-size: 1.5rem;
    }

    .hero-subtitle {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  // Fit carousel within remaining viewport below the header
  const header = document.querySelector('header');
  const hero = document.querySelector('.hero-carousel-section') as HTMLElement;
  if (header && hero) {
    const headerHeight = header.offsetHeight;
    hero.style.maxHeight = `calc(100vh - ${headerHeight}px)`;
  }

  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.hero-dot');
  const prevBtn = document.querySelector('.carousel-btn-prev');
  const nextBtn = document.querySelector('.carousel-btn-next');

  if (slides.length === 0) {
    console.warn('Carousel slides not found');
  } else {
    let currentIndex = 0;
    let autoplayTimeout: ReturnType<typeof setTimeout> | undefined;

    const clearScheduled = () => {
      clearTimeout(autoplayTimeout);
      for (const slide of slides) {
        const v = slide.querySelector('video');
        if (v) v.onended = null;
      }
    };

    const scheduleNext = () => {
      clearScheduled();
      const currentVideo = slides[currentIndex]?.querySelector('video');

      if (currentVideo) {
        currentVideo.onended = () => showSlide(currentIndex + 1);
      } else {
        autoplayTimeout = setTimeout(() => {
          showSlide(currentIndex + 1);
        }, 5000);
      }
    };

    const showSlide = (index: number) => {
      clearScheduled();

      const prevIndex = currentIndex;
      currentIndex = (index + slides.length) % slides.length;

      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === currentIndex);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
        dot.setAttribute('aria-current', String(i === currentIndex));
      });

      // Stop previous video
      const prevVideo = slides[prevIndex]?.querySelector('video');
      if (prevVideo) prevVideo.pause();

      // Play current video if present
      const currentVideo = slides[currentIndex]?.querySelector('video');
      if (currentVideo) {
        currentVideo.currentTime = 0;
        currentVideo.play();
      }

      scheduleNext();
    };

    prevBtn?.addEventListener('click', () => {
      showSlide(currentIndex - 1);
    });

    nextBtn?.addEventListener('click', () => {
      showSlide(currentIndex + 1);
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        showSlide(index);
      });
    });

    // Initialize
    showSlide(0);
  }
</script>
