---
import Button from "../Button.astro";
---

<section class="about-hero">
  <div class="container">
    <div class="hero-content">
      <h1>Welcome to Salinas de Guaranda</h1>
      <p class="subtitle">Where tourism builds community prosperity</p>
    </div>
  </div>
</section>

<style>
  .about-hero {
    padding: 4rem 1rem;
    background: var(--primary);
    color: white;
  }

  .container {
    margin: 0 auto;
  }

  .hero-content {
    text-align: center;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    text-wrap: balance;
  }

  .subtitle {
    font-size: 1.2rem;
    margin: 0 0 1rem 0;
    opacity: 0.95;
  }

  .description {
    font-size: 1.1rem;
    margin: 0 0 2rem 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
    opacity: 0.9;
  }

  .hero-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin: 3rem 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    backdrop-filter: blur(10px);
  }

  .feature-icon {
    font-size: 2rem;
  }

  .feature-text {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .about-hero {
      padding: 3rem 1rem;
    }

    h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.2rem;
    }

    .description {
      font-size: 1rem;
    }

    .hero-features {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin: 2rem 0;
    }

    .feature {
      padding: 1rem;
    }

    .hero-buttons {
      gap: 0.75rem;
    }
  }
</style>
