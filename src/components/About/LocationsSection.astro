---
import { locations } from "../../lib/about-data";
---

<section class="locations-section">
  <div class="container">
    <h2>Our Locations</h2>
    <p class="section-subtitle">Operating across Ecuador's diverse regions</p>
    
    <div class="locations-grid">
      {locations.map((location) => (
        <div class="location-card">
          <div class="location-emoji">{location.emoji}</div>
          <h3>{location.name}</h3>
          <p class="location-region">{location.region}</p>
          <p class="location-description">{location.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .locations-section {
    padding: 4rem 1rem;
    background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1.1rem;
    margin: 0 0 3rem 0;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .location-card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    border: 2px solid #e0e0e0;
    text-align: center;
    transition: all 300ms ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .location-card:hover {
    border-color: #2D5016;
    box-shadow: 0 8px 24px rgba(45, 80, 22, 0.15);
    transform: translateY(-4px);
  }

  .location-emoji {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .location-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.4rem;
    color: #2D5016;
    font-weight: 700;
  }

  .location-region {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    color: #8B7355;
    font-weight: 600;
  }

  .location-description {
    margin: 0;
    color: #666;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .locations-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 2rem;
    }

    .locations-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .location-card {
      padding: 1.5rem;
    }

    .location-emoji {
      font-size: 2.5rem;
    }

    .location-card h3 {
      font-size: 1.2rem;
    }
  }
</style>
