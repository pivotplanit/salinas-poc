---
import { people } from "../../lib/about-data";
---

<section class="people-section">
  <div class="container">
    <h2>Meet Our Team</h2>
    <p class="section-subtitle">Passionate leaders driving sustainable tourism</p>
    
    <div class="people-grid">
      {people.map((person) => (
        <div class="person-card">
          <div class="person-avatar">{person.avatar}</div>
          <h3>{person.name}</h3>
          <p class="person-role">{person.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .people-section {
    padding: 4rem 1rem;
    background: #f5f5f5;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1.1rem;
    margin: 0 0 3rem 0;
  }

  .people-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .person-card {
    background: white;
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    transition: all 300ms ease;
  }

  .person-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .person-avatar {
    font-size: 4rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .person-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.3rem;
    color: #2D5016;
  }

  .person-role {
    margin: 0;
    color: #8B7355;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .people-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 2rem;
    }

    .people-grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.5rem;
    }

    .person-card {
      padding: 1.5rem 1rem;
    }

    .person-avatar {
      font-size: 3rem;
    }
  }
</style>
