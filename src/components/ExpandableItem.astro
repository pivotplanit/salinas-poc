---
interface Props {
  title: string;
  content: string;
  defaultOpen?: boolean;
}

const { title, content, defaultOpen = false } = Astro.props;
const id = Math.random().toString(36).substring(2, 9);
---

<div class="expandable-item" data-open={defaultOpen}>
  <button class="expandable-header" aria-expanded={defaultOpen} aria-controls={id}>
    <span class="expandable-title">{title}</span>
    <span class="expandable-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </span>
  </button>
  <div class="expandable-content" id={id} style={!defaultOpen ? 'max-height: 0' : ''}>
    <div class="expandable-content-inner">
      {typeof content === 'string' ? <p set:html={content} /> : content}
    </div>
  </div>
</div>

<style>
  .expandable-item {
    border: 1px solid var(--border-color, #e0e0e0);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .expandable-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.25rem;
    background: var(--header-bg, #f5f5f5);
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    transition: background-color var(--transition-duration, 300ms) ease;
  }

  .expandable-header:hover {
    background: var(--header-hover-bg, #efefef);
  }

  .expandable-title {
    flex: 1;
    color: var(--text-color, #1a1a1a);
  }

  .expandable-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--icon-color, #666);
    transition: transform var(--transition-duration, 300ms) ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .expandable-item[data-open="true"] .expandable-icon {
    transform: rotate(180deg);
  }

  .expandable-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-duration, 300ms) ease;
  }

  .expandable-item[data-open="true"] .expandable-content {
    max-height: 1000px;
  }

  .expandable-content-inner {
    padding: 1.25rem;
    background: white;
    border-top: 1px solid var(--border-color, #e0e0e0);
    color: var(--text-color, #1a1a1a);
    line-height: 1.6;
  }

  .expandable-content-inner p {
    margin: 0;
  }

  .expandable-content-inner p + p {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .expandable-header {
      padding: 1rem;
    }

    .expandable-content-inner {
      padding: 1rem;
    }

    .expandable-icon {
      width: 20px;
      height: 20px;
      margin-left: 0.75rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.expandable-item').forEach((item) => {
    const header = item.querySelector('.expandable-header') as HTMLButtonElement;
    const content = item.querySelector('.expandable-content') as HTMLDivElement;

    if (!header || !content) return;

    const updateHeight = () => {
      const isOpen = item.getAttribute('data-open') === 'true';
      if (isOpen) {
        const innerContent = content.querySelector('.expandable-content-inner') as HTMLDivElement;
        if (innerContent) {
          content.style.maxHeight = innerContent.scrollHeight + 'px';
        }
      } else {
        content.style.maxHeight = '0';
      }
    };

    header.addEventListener('click', () => {
      const isOpen = item.getAttribute('data-open') === 'true';
      item.setAttribute('data-open', (!isOpen).toString());
      header.setAttribute('aria-expanded', (!isOpen).toString());
      updateHeight();
    });

    // Recalculate on resize
    window.addEventListener('resize', updateHeight);

    // Initial setup
    updateHeight();
  });
</script>
