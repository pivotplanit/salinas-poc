---
interface Slide {
  type: "image" | "video";
  src: string;
  alt: string;
  poster?: string;
}

interface Badge {
  label: string;
}

interface Props {
  slides?: Slide[];
  badges?: Badge[];
  caption?: string;
}

const { slides = [], badges = [], caption } = Astro.props;

const fallbackSrc = (index: number) => `https://picsum.photos/1600/900?random=${index + 1}`;

const displaySlides: Slide[] =
  slides.length > 0
    ? slides
    : [
        {
          type: "image",
          src: fallbackSrc(0),
          alt: "Experience highlight",
        },
      ];
---

<section class="exp-hero-section">
  <div class="exp-hero-container">
    <div class="exp-hero-main">
      {displaySlides.map((slide, index) => (
        <div
          class:list={['exp-hero-slide', { active: index === 0 }]}
          data-exp-slide={index}
        >
          {slide.type === 'video' ? (
            <video
              class="exp-hero-media"
              src={slide.src}
              poster={slide.poster}
              muted
              controls
              playsinline
              preload="metadata"
            />
          ) : (
            <img
              class="exp-hero-media"
              src={slide.src}
              alt={slide.alt}
              loading="eager"
              width={1600}
              height={900}
              onerror={`this.onerror=null;this.src='${fallbackSrc(index)}'`}
            />
          )}
        </div>
      ))}
    </div>

    {badges.length > 0 && (
      <div class="exp-hero-badges">
        {badges.map((badge) => (
          <span class="exp-hero-badge">{badge.label}</span>
        ))}
      </div>
    )}

    {displaySlides.length > 1 && (
      <>
        <button class="exp-hero-btn exp-hero-btn-prev" aria-label="Previous image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="exp-hero-btn exp-hero-btn-next" aria-label="Next image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </>
    )}

    <div class="exp-hero-bottom">
      <div class="exp-hero-indicators">
        {displaySlides.map((_, index) => (
          <button
            class:list={['exp-hero-dot', { active: index === 0 }]}
            data-exp-dot={index}
            aria-label={`Go to image ${index + 1}`}
            aria-current={index === 0}
          ></button>
        ))}
      </div>
      {caption && (
        <p class="exp-hero-caption">{caption}</p>
      )}
    </div>
  </div>
</section>

<style>
  .exp-hero-section {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 70vh;
    overflow: hidden;
    background: var(--medium-gray);
  }

  .exp-hero-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .exp-hero-main {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .exp-hero-slide {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-in-out;
    background: var(--medium-gray);
    z-index: 1;
  }

  .exp-hero-slide.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .exp-hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom;
    display: block;
  }

  /* Badges */
  .exp-hero-badges {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    z-index: 10;
    justify-content: flex-end;
  }

  .exp-hero-badge {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(0, 0, 0, 0.12);
    color: #333;
    white-space: nowrap;
    backdrop-filter: blur(6px);
    line-height: 1.4;
  }

  /* Prev/Next buttons */
  .exp-hero-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 300ms ease;
    backdrop-filter: blur(10px);
    z-index: 10;
  }

  .exp-hero-btn-prev {
    left: 2rem;
  }

  .exp-hero-btn-next {
    right: 2rem;
  }

  .exp-hero-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    border-color: white;
    transform: translateY(-50%) scale(1.1);
  }

  .exp-hero-btn:active {
    transform: translateY(-50%) scale(0.95);
  }

  /* Bottom area: dots + caption */
  .exp-hero-bottom {
    position: absolute;
    bottom: 1.5rem;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
  }

  .exp-hero-indicators {
    display: flex;
    gap: 0.5rem;
  }

  .exp-hero-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: all 300ms ease;
  }

  .exp-hero-dot:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .exp-hero-dot.active {
    background: white;
    width: 32px;
    border-radius: 5px;
  }

  .exp-hero-caption {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 768px) {
    .exp-hero-btn {
      width: 40px;
      height: 40px;
    }

    .exp-hero-btn-prev {
      left: 1rem;
    }

    .exp-hero-btn-next {
      right: 1rem;
    }

    .exp-hero-badges {
      top: 0.75rem;
      right: 0.75rem;
      gap: 0.375rem;
    }

    .exp-hero-badge {
      font-size: 0.675rem;
      padding: 0.2rem 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .exp-hero-btn {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  const section = document.querySelector('.exp-hero-section');
  if (section) {
    const slides = section.querySelectorAll('.exp-hero-slide');
    const dots = section.querySelectorAll('.exp-hero-dot');
    const prevBtn = section.querySelector('.exp-hero-btn-prev');
    const nextBtn = section.querySelector('.exp-hero-btn-next');

    if (slides.length > 0) {
      let currentIndex = 0;
      let autoplayTimeout: ReturnType<typeof setTimeout> | undefined;

      const clearScheduled = () => {
        clearTimeout(autoplayTimeout);
        for (const slide of slides) {
          const v = slide.querySelector('video');
          if (v) v.onended = null;
        }
      };

      const showSlide = (index: number) => {
        clearScheduled();

        const prevIndex = currentIndex;
        currentIndex = (index + slides.length) % slides.length;

        slides.forEach((slide, i) => {
          slide.classList.toggle('active', i === currentIndex);
        });

        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
          dot.setAttribute('aria-current', String(i === currentIndex));
        });

        // Stop previous video
        const prevVideo = slides[prevIndex]?.querySelector('video');
        if (prevVideo) prevVideo.pause();

        // Play current video if present
        const currentVideo = slides[currentIndex]?.querySelector('video');
        if (currentVideo) {
          currentVideo.currentTime = 0;
          currentVideo.play();
        }

        scheduleNext();
      };

      const scheduleNext = () => {
        clearScheduled();
        const currentVideo = slides[currentIndex]?.querySelector('video');

        if (currentVideo) {
          currentVideo.onended = () => showSlide(currentIndex + 1);
        } else {
          autoplayTimeout = setTimeout(() => {
            showSlide(currentIndex + 1);
          }, 5000);
        }
      };

      prevBtn?.addEventListener('click', () => {
        showSlide(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', () => {
        showSlide(currentIndex + 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          showSlide(index);
        });
      });

      // Initialize
      showSlide(0);
    }
  }
</script>
