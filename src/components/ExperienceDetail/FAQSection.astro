---
import FAQItem from "../FAQItem.astro";

interface Props {
  faqs?: Array<{
    question: string;
    answer: string;
  }>;
}

const { faqs = [] } = Astro.props;
---

{faqs.length > 0 && (
  <section class="detail-faq-section">
    <h2>Frequently Asked Questions</h2>
    
    <div class="faq-container">
      {faqs.map((faq, index) => (
        <FAQItem
          question={faq.question}
          answer={faq.answer}
          defaultOpen={index === 0}
        />
      ))}
    </div>
  </section>
)}

<style>
  .detail-faq-section {
    padding: 3rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 2rem 0;
    text-align: center;
  }

  .faq-container {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
  }

  :global(.faq-container .faq-item) {
    padding: 1.5rem;
    border: none;
  }

  :global(.faq-container .faq-item:not(:last-child)) {
    border-bottom: 1px solid #e0e0e0;
  }

  @media (max-width: 768px) {
    .detail-faq-section {
      padding: 2rem 0;
    }

    h2 {
      font-size: 1.5rem;
    }

    :global(.faq-container .faq-item) {
      padding: 1.25rem;
    }
  }
</style>
