---
interface Props {
  highlights?: string[];
}

const { highlights = [] } = Astro.props;

// Split highlights into two columns
const midpoint = Math.ceil(highlights.length / 2);
const leftColumn = highlights.slice(0, midpoint);
const rightColumn = highlights.slice(midpoint);
---

{highlights.length > 0 && (
  <section class="highlights-section">
    <h2>Highlights</h2>
    <div class="highlights-columns">
      <ul class="highlights-list">
        {leftColumn.map((highlight) => (
          <li>{highlight}</li>
        ))}
      </ul>
      <ul class="highlights-list">
        {rightColumn.map((highlight) => (
          <li>{highlight}</li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .highlights-section {
    padding: 3rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1.5rem 0;
  }

  .highlights-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 3rem;
  }

  .highlights-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlights-list li {
    position: relative;
    padding: 0.5rem 0 0.5rem 1.5rem;
    color: #444;
    font-size: 0.95rem;
    line-height: 1.6;
    border-bottom: 1px solid #f0f0f0;
  }

  .highlights-list li:last-child {
    border-bottom: none;
  }

  .highlights-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 700;
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .highlights-columns {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 1.5rem;
    }
  }
</style>
