---
interface Props {
  included?: string[];
  excluded?: string[];
}

const { included = [], excluded = [] } = Astro.props;
---

{(included.length > 0 || excluded.length > 0) && (
  <section class="included-section">
    <div class="included-grid">
      {included.length > 0 && (
        <div class="included-column">
          <h3>
            <span class="header-icon included-icon">✓</span>
            What's Included
          </h3>
          <ul>
            {included.map((item) => (
              <li class="item-included">
                <span class="check-icon">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {excluded.length > 0 && (
        <div class="excluded-column">
          <h3>
            <span class="header-icon excluded-icon">✗</span>
            Not Included
          </h3>
          <ul>
            {excluded.map((item) => (
              <li class="item-excluded">
                <span class="x-icon">✗</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .included-section {
    padding: 3rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  .included-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header-icon {
    font-size: 0.9rem;
  }

  .included-icon {
    color: #4CAF50;
  }

  .excluded-icon {
    color: #F44336;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.6rem 0;
    font-size: 0.95rem;
    color: #444;
    line-height: 1.5;
  }

  .check-icon {
    color: #4CAF50;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .x-icon {
    color: #F44336;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  @media (max-width: 768px) {
    .included-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
