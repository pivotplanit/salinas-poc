---
import { contact } from "../../lib/constants";
import IconRenderer from "@components/IconRenderer.astro";
---

<div class="need-help" id="contact">
  <h3>Need Help?</h3>
  <ul class="contact-list">
    <li>
      <div><IconRenderer icon="Phone" size={15}/></div>
      <a href={`tel:${contact.phone}`} class="contact-list-info">
        <p class="contact-list-header">Call Us</p>
        <p class="contact-list-value">{contact.phone}</p>
      </a>
    </li>
    <li>
      <div><IconRenderer icon="Mail" size={15}/></div>
      <a href={`mailto:${contact.email}`} class="contact-list-info">
        <p class="contact-list-header">Email Us</p>
        <p class="contact-list-value">{contact.email}</p>
      </a>
    </li>
    <li class="contact-whatsapp">
      <div><IconRenderer icon="WhatsApp" size={15}/></div>
      <a href={`https://wa.me/${contact.whatsapp.replace(/[^0-9]/g, '')}`} target="_blank" class="contact-list-info">
        <p class="contact-list-header">WhatsApp</p>
        <p class="contact-list-value">Quick response</p>
      </a>
    </li>
  </ul>
</div>

<style>
  .need-help {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .section-label {
    font-size: 0.7rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 0.5rem 0;
    font-weight: 600;
  }

  h3 {
    margin: 0 0 1rem 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    flex-direction: column;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    font-size: 0.9rem;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
  }

  .contact-list li div:first-child {
    width: 36px;
    height: 36px;
    border: 1px solid #E5E7EB;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tertiary);
  }

  .contact-list li:nth-child(3),
  .contact-list li:nth-child(3) div {
    color: #6B9B37;
    border: 1px solid #6B9B374D;
  }
  .contact-icon {
    flex-shrink: 0;
  }

  .contact-list a {
    color: #444;
    text-decoration: none;
  }

  .contact-list a:hover {
    color: var(--primary);
  }

  .contact-list-info {
    display: flex;
    flex-direction: column;
  }

  .contact-list-header {
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .contact-list-value {
    color: #4B5563;
    font-size: 0.7rem;
    font-weight: 700;
  }
</style>
