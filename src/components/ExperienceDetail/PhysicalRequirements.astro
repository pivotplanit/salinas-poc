---
interface Props {
  walking?: string;
  accessibility?: string;
  altitude?: string;
  notSuitableFor?: string;
}

const { walking, accessibility, altitude, notSuitableFor } = Astro.props;
---

{(walking || accessibility || notSuitableFor) && (
  <section class="requirements-section">
    <h2>Physical Requirements</h2>
    <p class="section-subtitle">Requirements Info</p>
    <div class="requirements-grid">
      {walking && (
        <div class="requirement-item">
          <span class="req-label">Walking:</span>
          <span class="req-value">{walking}</span>
        </div>
      )}
      {accessibility && (
        <div class="requirement-item">
          <span class="req-label">Accessible for:</span>
          <span class="req-value">{accessibility}</span>
        </div>
      )}
      {altitude && (
        <div class="requirement-item">
          <span class="req-label">Altitude:</span>
          <span class="req-value">{altitude}</span>
        </div>
      )}
      {notSuitableFor && (
        <div class="requirement-item">
          <span class="req-label">Not suitable for:</span>
          <span class="req-value">{notSuitableFor}</span>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .requirements-section {
    padding: 3rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.25rem 0;
  }

  .section-subtitle {
    font-size: 0.9rem;
    color: #999;
    margin: 0 0 1.5rem 0;
  }

  .requirements-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .requirement-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .req-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .req-value {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .requirements-grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 1.5rem;
    }
  }
</style>
