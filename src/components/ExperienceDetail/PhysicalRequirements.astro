---
interface Props {
  walking?: string;
  accessibility?: string;
  altitude?: string;
  notSuitableFor?: string;
}

const { walking, accessibility, altitude, notSuitableFor } = Astro.props;
---

{(walking || accessibility || notSuitableFor) && (
  <section class="requirements-section">
    <h2>Physical Requirements</h2>
    <div class="requirements-grid">
      {walking && (
        <div class="requirement-item">
          <span class="req-label">Walking:</span>
          <span class="req-value">{walking}</span>
        </div>
      )}
      {accessibility && (
        <div class="requirement-item">
          <span class="req-label">Accessible for:</span>
          <span class="req-value">{accessibility}</span>
        </div>
      )}
      {altitude && (
        <div class="requirement-item">
          <span class="req-label">Altitude:</span>
          <span class="req-value">{altitude}</span>
        </div>
      )}
      {notSuitableFor && (
        <div class="requirement-item">
          <span class="req-label">Not suitable for:</span>
          <span class="req-value">{notSuitableFor}</span>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .requirements-section {
    padding: 1rem 0;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1.5rem 0;
  }

  .section-subtitle {
    font-size: 0.9rem;
    color: #999;
    margin: 0 0 1.5rem 0;
  }

  .requirements-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid #2B6CB033;
    border-radius: 6px;
    background-color: #E8F4FD;
    color: #4B5563;
  }

  .requirement-item {
    display: flex;
    gap: 0.5rem;
  }

  .requirement-item > :first-child {
    flex-shrink: 0;
  }

  .req-label {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .req-value {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .requirements-grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 1.5rem;
    }
  }
</style>
