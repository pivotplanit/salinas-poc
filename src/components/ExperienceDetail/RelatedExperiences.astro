---
import { experiences } from "../../lib/experiences-data";

interface Props {
  currentId?: string;
  relatedIds?: string[];
}

const { currentId = "", relatedIds = [] } = Astro.props;

// Get related experiences
const relatedExperiences = relatedIds
  .map((id) => experiences.find((exp) => exp.id === id))
  .filter((exp) => exp && exp.id !== currentId)
  .slice(0, 3);

if (relatedExperiences.length === 0) {
  relatedExperiences.push(...experiences.filter((exp) => exp.id !== currentId).slice(0, 3));
}
---

{relatedExperiences.length > 0 && (
  <section class="related-section">
    <h2>Similar Experiences</h2>
    <p class="section-subtitle">Explore other amazing activities</p>
    
    <div class="related-grid">
      {relatedExperiences.map((exp) => (
        <a href={`/experiences/${exp?.id}`} class="related-card">
          <div class="related-emoji">{exp?.icon}</div>
          <h3>{exp?.title}</h3>
          <p class="related-tag">{exp?.tag}</p>
          <p class="related-description">{exp?.description}</p>
          
          <div class="related-meta">
            <span class="meta">⏱️ {exp?.duration}</span>
            <span class="meta">📍 {exp?.altitude}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    padding: 3rem 0;
    border-bottom: 1px solid #e0e0e0;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1rem;
    margin: 0 0 2rem 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: #f9f9f9;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    text-decoration: none;
    color: inherit;
    transition: all 300ms ease;
  }

  .related-card:hover {
    border-color: #2D5016;
    box-shadow: 0 8px 24px rgba(45, 80, 22, 0.1);
    transform: translateY(-4px);
    background: white;
  }

  .related-emoji {
    font-size: 3rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .related-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
    color: #2D5016;
    font-weight: 600;
  }

  .related-tag {
    margin: 0 0 0.75rem 0;
    font-size: 0.85rem;
    color: #8B7355;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .related-description {
    margin: 0 0 1rem 0;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .related-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid #e0e0e0;
    padding-top: 1rem;
    font-size: 0.85rem;
    color: #666;
  }

  .meta {
    display: block;
  }

  @media (max-width: 768px) {
    .related-section {
      padding: 2rem 0;
    }

    h2 {
      font-size: 1.5rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .related-card {
      padding: 1.25rem;
    }
  }
</style>
