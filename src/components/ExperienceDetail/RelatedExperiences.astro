---
import { experiences } from "../../lib/experiences-data";
import Button from "../Button.astro";

interface Props {
  currentId?: string;
  relatedIds?: string[];
  locale?: string;
}

const { currentId = "", relatedIds = [], locale = "en" } = Astro.props;

const relatedExperiences = relatedIds
  .map((id) => experiences.find((exp) => exp.id === id))
  .filter((exp) => exp && exp.id !== currentId)
  .slice(0, 3);

if (relatedExperiences.length === 0) {
  relatedExperiences.push(...experiences.filter((exp) => exp.id !== currentId).slice(0, 3));
}
---

{relatedExperiences.length > 0 && (
  <section class="related-section">
    <h2>Related Experiences</h2>
    <div class="related-grid">
      {relatedExperiences.map((exp) => (
        <div class="related-card">
          <div class="card-image">
            {exp?.image ? (
              <img src={exp.image} alt={exp?.title} loading="lazy" />
            ) : (
              <div class="card-image-placeholder">
                <span>{exp?.icon}</span>
              </div>
            )}
          </div>
          <div class="card-body">
            <h3>{exp?.title}</h3>
            <div class="card-meta">
              <span class="card-duration">{exp?.duration}</span>
              <span class="card-price">
                {typeof exp?.price === 'number' ? `$${exp.price}` : exp?.price || 'Contact'}
              </span>
            </div>
            <Button
              text="View Details"
              href={`/experiences/${exp?.id}`}
              variant="outline"
              size="sm"
              fullWidth
            />
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 2rem 0;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .related-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    background: white;
  }

  .card-label {
    font-size: 0.7rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 0.75rem 1rem 0;
    margin: 0;
    font-weight: 600;
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #f5f5f5;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
  }

  .card-body {
    padding: 1rem;
  }

  .card-body h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: #666;
  }

  .card-price {
    font-weight: 600;
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .related-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    h2 {
      font-size: 1.5rem;
    }
  }
</style>
