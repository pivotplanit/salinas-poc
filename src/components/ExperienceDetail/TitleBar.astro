---
import Button from "../Button.astro";

interface Props {
  title: string;
  tag: string;
  duration: string;
  difficulty: string;
  altitude: string;
  groupSize: string;
}

const { title, tag, duration, difficulty, altitude, groupSize } = Astro.props;
---

<section class="title-bar" id="title-bar">
  <div class="title-section">
    <div class="container">
      <h1>{title}</h1>
    </div>
  </div>
  <div class="meta-bar">
    <div class="container">
      <div class="meta-bar-inner">
        <div class="meta-badges">
          <div class="meta-badge">
            <span class="meta-label">Duration</span>
            <span class="meta-value">{duration}</span>
          </div>
          <div class="meta-badge">
            <span class="meta-label">Difficulty</span>
            <span class="meta-value">{difficulty}</span>
          </div>
          <div class="meta-badge">
            <span class="meta-label">Altitude</span>
            <span class="meta-value">{altitude}</span>
          </div>
          <div class="meta-badge">
            <span class="meta-label">Group</span>
            <span class="meta-value">{groupSize}</span>
          </div>
        </div>
        <!-- <span class="category-tag">{tag}</span> -->
        <div class="action-buttons">
          <Button href="#booking" variant="primary" size="sm" text="Book" />
          <Button href="#contact" variant="outline" size="sm" text="Contact" />
          <button class="share-btn" type="button" aria-label="Share">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
              <polyline points="16 6 12 2 8 6" />
              <line x1="12" y1="2" x2="12" y2="15" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .title-bar {
    position: sticky;
    top: var(--header-height, 60px);
    z-index: 90;
  }

  .title-section {
    background: var(--primary);
    padding: 3rem 1rem;
    color: white;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
  }

  .meta-bar {
    background: white;
    border-bottom: 1px solid #e0e0e0;
    padding: 1rem;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .meta-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .meta-badges {
    display: flex;
    gap: 2rem;
  }

  .meta-badge {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #999;
    font-weight: 600;
  }

  .meta-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: #333;
  }

  .category-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--primary);
    color: white;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .action-buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #e0e0e0;
    background: transparent;
    color: #666;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .share-btn:hover {
    background: #f5f5f5;
    color: var(--primary);
    border-color: var(--primary);
  }

  @media (max-width: 768px) {
    .title-section {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 1.75rem;
    }

    .meta-bar-inner {
      flex-direction: column;
      gap: 1rem;
      align-items: stretch;
    }

    .meta-badges {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .category-tag {
      align-self: flex-start;
    }

    .action-buttons {
      width: 100%;
    }

    .action-buttons :global(.btn) {
      flex: 1;
    }
  }
</style>

<script>
  const header = document.querySelector('header');
  const titleBar = document.getElementById('title-bar');
  if (header && titleBar) {
    const updateHeight = () => {
      titleBar.style.setProperty('--header-height', `${header.offsetHeight}px`);
    };
    updateHeight();
    window.addEventListener('resize', updateHeight);
  }
</script>
