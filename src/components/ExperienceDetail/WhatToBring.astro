---
interface Props {
  items?: string[];
}

const { items = [] } = Astro.props;

const midpoint = Math.ceil(items.length / 2);
const leftColumn = items.slice(0, midpoint);
const rightColumn = items.slice(midpoint);
---

{items.length > 0 && (
  <section class="bring-section">
    <h2>What to Bring</h2>
    <div class="bring-columns">
      <ul class="bring-list">
        {leftColumn.map((item) => (
          <li>
            <span class="checkbox-icon">☐</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <ul class="bring-list">
        {rightColumn.map((item) => (
          <li>
            <span class="checkbox-icon">☐</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .bring-section {
    padding: 1rem 0;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1.5rem 0;
  }

  .section-subtitle {
    font-size: 0.9rem;
    color: #999;
    margin: 0 0 1.5rem 0;
  }

  .bring-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 3rem;
    border: 1px solid #F3F4F6;
    border-radius: 6px;
    padding: 2rem;
    font-weight: 700;
  }

  .bring-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bring-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: #374151;
    font-size: 0.75rem;
  }

  .checkbox-icon {
    color: #999;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .bring-columns {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 1.5rem;
    }
  }
</style>
