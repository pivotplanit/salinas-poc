---
import { Image } from "astro:assets";
import Button from "../Button.astro";

export interface Props {
  id: string;
  title: string;
  category: string;
  description: string;
  duration: string;
  difficulty: string;
  difficultyLevel: number;
  altitude: string;
  groupSize: string;
  image?: string;
}

const {
  id,
  title,
  category,
  description,
  duration,
  difficulty,
  difficultyLevel,
  altitude,
  groupSize,
  image,
} = Astro.props;

// Generate difficulty badges
const badges = Array.from({ length: 3 }, (_, i) => i < difficultyLevel);
---

<div class="experience-card">
  <div class="experience-card-image">
    {image && (
      <img 
        src={image}
        alt={title}
        width={800}
        height={450}
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <div class="experience-card-content">
    <p class="experience-card-tag">{category}</p>
    <h3>{title}</h3>
    <p class="experience-description">{description}</p>
    <div class="experience-meta">
      <span class="meta-item">⏱️ {duration}</span>
      <span class="meta-item">🎯 {difficulty}</span>
    </div>
    <div class="difficulty-badges">
      {badges.map((filled) => (
        <span class={`difficulty-badge ${filled ? 'filled' : ''}`}></span>
      ))}
    </div>
    <div class="experience-details-list">
      <span>🗻 Altitude: {altitude}</span>
      <span>👥 Group: {groupSize}</span>
    </div>
    <Button href={`/experiences/${id}`} variant="outline" size='sm'>Learn More →</Button>
  </div>
</div>

<style>
  .experience-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .experience-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .experience-card-image {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f5f5 0%, #efefef 100%);
    overflow: hidden;
    position: relative;
  }

  .experience-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .experience-card-content {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .experience-card-tag {
    font-size: 12px;
    font-weight: 600;
    color: #666;
    text-transform: uppercase;
    margin: 0 0 8px 0;
    letter-spacing: 0.5px;
  }

  h3 {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
    color: #222;
    line-height: 1.4;
  }

  .experience-description {
    font-size: 13px;
    color: #666;
    margin: 0 0 12px 0;
    line-height: 1.5;
    flex: 1;
  }

  .experience-meta {
    display: flex;
    gap: 12px;
    margin: 12px 0;
    font-size: 13px;
    color: #555;
  }

  .experience-card-button {
    font-size: 0.7rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .difficulty-badges {
    display: flex;
    gap: 6px;
    margin: 12px 0;
  }

  .difficulty-badge {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ddd;
    border: 1px solid #bbb;
  }

  .difficulty-badge.filled {
    background: #2ecc71;
    border-color: #27ae60;
  }

  .experience-details-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: #666;
    margin: 12px 0;
  }

  :global(.btn) {
    margin-top: auto;
  }

  @media (max-width: 767px) {
    .experience-card-image {
      font-size: 40px;
    }

    h3 {
      font-size: 15px;
    }

    .experience-description {
      font-size: 12px;
    }
  }
</style>
