---
import { Image } from "astro:assets";
import Button from "../Button.astro";
import IconRenderer from "@components/IconRenderer.astro";

export interface Props {
  id: string;
  title: string;
  category: string;
  description: string;
  duration: string;
  difficulty: string;
  difficultyLevel: number;
  altitude?: string;
  groupSize: string;
  image?: string;
}

const {
  id,
  title,
  category,
  description,
  duration,
  difficulty,
  difficultyLevel,
  altitude,
  groupSize,
  image,
} = Astro.props;

// Generate difficulty badges
const badges = Array.from({ length: 3 }, (_, i) => i < difficultyLevel);

const altitudeDisplay = altitude && altitude.trim() !== "" ? altitude : "N/A";
const ICON_COLOR = "#7B8FA1";
---

<div class="experience-card">
  <div class="experience-card-image">
    {image && (
      <img 
        src={image}
        alt={title}
        width={800}
        height={450}
        loading="lazy"
        decoding="async"
      />
    )}
    <div class={`category-badge category-${category.toLowerCase().replace(/\s+/g, '-')}`}>{category}</div>
  </div>
  <div class="experience-card-content">
    <div class="experience-duration">
      <IconRenderer icon="Clock" size={16} color={ICON_COLOR} />
      <span>{duration}</span>
    </div>
    <h3>{title}</h3>
    <p class="experience-description">{description}</p>
    <div class="difficulty-row">
      <div class="difficulty-badges">
        {badges.map((filled) => (
          <span class={`difficulty-badge ${filled ? 'filled' : ''}`}></span>
        ))}
      </div>
      <span class="difficulty-text">{difficulty}</span>
    </div>
    <div class="experience-details-list">
      <span class="detail-row">
        <IconRenderer icon="Mountain" size={16} color={ICON_COLOR} />
        <span>Altitude: {altitudeDisplay}</span>
      </span>
      <span class="detail-row">
        <IconRenderer icon="Users" size={16} color={ICON_COLOR} />
        <span>Group: {groupSize}</span>
      </span>
    </div>
    <Button href={`/experiences/${id}`} variant="outline" size='sm'>Learn More →</Button>
  </div>
</div>

<style>
  .experience-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .experience-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .experience-card-image {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f5f5 0%, #efefef 100%);
    overflow: hidden;
    position: relative;
  }

  .experience-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--text-medium);
    color: var(--white);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 5;
  }

  .category-badge.category-cultural {
    background: #2B6CB0;
  }

  .category-badge.category-adventure {
    background: #6B9B37;
  }

  .category-badge.category-gastronomic {
    background: #F59E0B;
  }

  .category-badge.category-nature {
    background: #2F855A;
  }

  .category-badge.category-multi-day {
    background: #805AD5;
  }

  .experience-card-content {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  h3 {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
    color: #222;
    line-height: 1.4;
  }

  .experience-description {
    font-size: 13px;
    color: #666;
    margin: 0 0 12px 0;
    line-height: 1.5;
    flex: 1;
  }

  .experience-duration {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #555;
    margin: 0 0 8px 0;
  }

  .experience-card-button {
    font-size: 0.7rem;
  }

  .difficulty-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 12px 0;
  }

  .difficulty-badges {
    display: flex;
    gap: 6px;
  }

  .difficulty-badge {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: #6B9B374D;
  }

  .difficulty-badge.filled {
    background: #6B9B37;
  }

  .difficulty-text {
    font-size: 13px;
    color: #555;
  }

  .experience-details-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: #666;
    margin: 12px 0;
  }

  .detail-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  :global(.btn) {
    margin-top: auto;
  }

  @media (max-width: 767px) {
    .experience-card-image {
      font-size: 40px;
    }

    h3 {
      font-size: 15px;
    }

    .experience-description {
      font-size: 12px;
    }
  }
</style>
