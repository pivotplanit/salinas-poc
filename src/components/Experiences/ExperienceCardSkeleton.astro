---
import SkeletonLoader from "../SkeletonLoader.astro";
---

<div class="skeleton-card">
  <div class="skeleton-image">
    <SkeletonLoader type="rectangular" width="100%" height="120px" />
  </div>
  <div class="skeleton-content">
    <div class="skeleton-tag">
      <SkeletonLoader type="rounded" width="60px" height="16px" />
    </div>
    <div class="skeleton-title">
      <SkeletonLoader type="rounded" width="100%" height="18px" />
    </div>
    <div class="skeleton-description">
      <SkeletonLoader type="rounded" width="100%" height="12px" />
      <SkeletonLoader type="rounded" width="85%" height="12px" />
    </div>
    <div class="skeleton-meta">
      <SkeletonLoader type="rounded" width="40%" height="14px" />
      <SkeletonLoader type="rounded" width="45%" height="14px" />
    </div>
    <div class="skeleton-badges">
      <SkeletonLoader type="circle" width="8px" height="8px" />
      <SkeletonLoader type="circle" width="8px" height="8px" />
      <SkeletonLoader type="circle" width="8px" height="8px" />
    </div>
    <div class="skeleton-details">
      <SkeletonLoader type="rounded" width="100%" height="12px" />
      <SkeletonLoader type="rounded" width="100%" height="12px" />
    </div>
    <div class="skeleton-button">
      <SkeletonLoader type="rounded" width="100%" height="36px" />
    </div>
  </div>
</div>

<style>
  .skeleton-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .skeleton-image {
    width: 100%;
    height: 120px;
    background: linear-gradient(135deg, #f5f5f5 0%, #efefef 100%);
  }

  .skeleton-content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .skeleton-tag {
    margin-bottom: 4px;
  }

  .skeleton-title {
    margin: 4px 0;
  }

  .skeleton-description {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 8px 0;
  }

  .skeleton-meta {
    display: flex;
    gap: 12px;
    margin: 8px 0;
  }

  .skeleton-badges {
    display: flex;
    gap: 6px;
    margin: 8px 0;
  }

  .skeleton-details {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 8px 0;
  }

  .skeleton-button {
    margin-top: auto;
  }

  @media (max-width: 767px) {
    .skeleton-image {
      height: 100px;
    }
  }
</style>
