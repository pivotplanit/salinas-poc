---
import { Image } from "astro:assets";
import { getRelativeLocaleUrl } from "astro:i18n";
import facebookLogoSrc from "../assets/images/Facebook_Logo.png";
import instagramLogoSrc from "../assets/images/Instagram_Logo.png";

// Cloudflare's worker-configuration.d.ts declares a global `ImageMetadata`
// interface that shadows Astro's, causing PNG imports to be typed incorrectly.
// Cast through `any` so the <Image> component accepts them.
// biome-ignore lint/suspicious/noExplicitAny: see comment above
const facebookLogo = facebookLogoSrc as any;
// biome-ignore lint/suspicious/noExplicitAny: see comment above
const instagramLogo = instagramLogoSrc as any;

const currentYear = new Date().getFullYear();

const { locale = "en" } = Astro.params;

const getLocalizedHref = (href: string): string => {
  return `${getRelativeLocaleUrl(locale, href)}`;
};
---

<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h4>HABITAT</h4>
      <p class="footer-description">Sustainable tourism in Salinas de Guaranda.</p>
      <div class="footer-social">
        <a href="#" aria-label="Facebook">
          <Image src={facebookLogo} alt="Facebook" width={32} height={32} />
        </a>
        <a href="#" aria-label="Instagram">
          <Image src={instagramLogo} alt="Instagram" width={32} height={32} />
        </a>
      </div>
    </div>

    <div class="footer-section">
      <h4>Experiences</h4>
      <ul>
        <li><a href={getLocalizedHref("/experiences")}>Natural Wonders</a></li>
        <li><a href={getLocalizedHref("/experiences")}>Cultural Immersion</a></li>
        <li><a href={getLocalizedHref("/experiences")}>Gastronomic</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Company</h4>
      <ul>
        <li><a href={getLocalizedHref("/about")}>About Salinas</a></li>
        <li><a href="#">Impact Report</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Newsletter</h4>
      <form id="newsletter-form" >
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          class="newsletter-input"
          required
        />
        <button type="submit" class="btn newsletter-btn">Join</button>
      </form>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} Habitat Travel Tours. All rights reserved.</p>
    <div class="footer-bottom-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0F2A42;
    color: white;
    padding: 3rem 2rem 1rem;
    border: 1px solid var(--primary);
  }

  footer a {
    color: inherit;
    text-decoration: none;
    font-size: 0.75rem;
    transition: color 0.3s;
  }

  footer a:hover {
    color: #FFFFFF1A;
  }

  .footer-content {
    max-width: 1600px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .footer-section {
    padding: 0 1rem;
  }

  .footer-section h4 {
    margin: 0 0 1rem 0;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #2B6CB033;
    border-radius: 50%;
    transition: background 0.3s;
    font-size: 1rem;
  }

  .footer-social a:hover {
    background: var(--primary);
  }

  .footer-section input {
    padding: 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .footer-description {
    font-size: 0.85rem;
    margin: 0 0 1rem 0;
    line-height: 1.5;
  }

  #newsletter-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .newsletter-btn {
    margin: 0;
    white-space: nowrap;
    background: var(--lush-green);
  }

  .newsletter-btn:hover {
    background-color: rgb(from var(--lush-green) r g b / 0.5);
  }

  .footer-bottom {
    border-top: 1px solid var(--primary);
    padding-top: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    gap: 1rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-bottom-links {
    display: flex;
    gap: 2rem;
  }

  .footer-bottom a {
    text-decoration: none;
    transition: color 0.3s;
    font-size: 0.85rem;
  }

  .footer-bottom a:hover {
    color: var(--accent-purple);
  }

  @media (max-width: 1024px) {
    footer {
      padding: 2rem 1.5rem 0.75rem;
    }

    .footer-content {
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .footer-section {
      padding: 0 0.75rem;
    }

    .footer-section h4 {
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }

    .footer-description {
      font-size: 0.8rem;
    }

    .newsletter-input {
      min-width: 150px;
      font-size: 0.8rem;
    }

    .footer-bottom {
      padding-top: 1.5rem;
      font-size: 0.8rem;
    }

    .footer-bottom-links {
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 2rem 1rem 0.75rem;
    }

    .footer-content {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .footer-section {
      padding: 0;
    }

    .footer-section h4 {
      font-size: 0.85rem;
      margin-bottom: 0.6rem;
    }

    .footer-section li {
      margin-bottom: 0.4rem;
    }

    .footer-description {
      font-size: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .footer-social {
      gap: 0.75rem;
    }

    .footer-social a {
      width: 36px;
      height: 36px;
      font-size: 0.9rem;
    }

    footer a {
      font-size: 0.8rem;
    }

    #newsletter-form {
      gap: 0.35rem;
    }

    .newsletter-input {
      min-width: 120px;
      padding: 0.4rem;
      font-size: 0.75rem;
    }

    .newsletter-btn {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
      padding-top: 1rem;
    }

    .footer-bottom-links {
      gap: 1.25rem;
    }

    .footer-bottom a {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: 2rem 1.25rem 1rem;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .footer-section {
      padding: 0;
    }

    .footer-section h4 {
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
      font-weight: 700;
    }

    .footer-section li {
      margin-bottom: 0.5rem;
    }

    .footer-description {
      font-size: 0.85rem;
      margin-bottom: 1rem;
      line-height: 1.5;
    }

    .footer-social {
      gap: 0.75rem;
      margin-top: 0.75rem;
    }

    .footer-social a {
      width: 32px;
      height: 32px;
      font-size: 0.9rem;
      flex-shrink: 0;
    }

    footer a {
      font-size: 0.85rem;
      line-height: 1.4;
    }

    #newsletter-form {
      flex-direction: row;
      gap: 0.5rem;
      flex-wrap: nowrap;
    }

    .newsletter-input {
      flex: 1;
      width: auto;
      min-width: 0;
      padding: 0.6rem 0.75rem;
      font-size: 0.85rem;
      height: auto;
    }

    .newsletter-btn {
      width: auto;
      padding: 0.6rem 1.25rem;
      font-size: 0.85rem;
      height: auto;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      padding-top: 1.25rem;
      text-align: center;
    }

    .footer-bottom p {
      font-size: 0.8rem;
      line-height: 1.4;
    }

    .footer-bottom-links {
      gap: 1.25rem;
      justify-content: center;
    }

    .footer-bottom a {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const GOOGLE_FORM_ACTION =
    'https://docs.google.com/forms/d/e/1FAIpQLSeXnP-5TcqQVSrR8NLXSb0_CE56qsoAayN6_j0rBnwBXoJVsw/formResponse';
  const EMAIL_ENTRY_ID = 'entry.828768216';
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email');

    const body = new FormData();
    body.append(EMAIL_ENTRY_ID, String(email ?? ''));
//
    try {
      // no-cors: response is opaque so we can't read success/failure,
      // but the submission still reaches Google. We optimistically show success.
      await fetch(GOOGLE_FORM_ACTION, {
        method: 'POST',
        mode: 'no-cors',
        body,
      });
      alert('Thank you for subscribing to our newsletter!');
    } catch {
      alert('Something went wrong. Please try again later.');
    }

    window.location.href = window.location.pathname;
  });
</script>