---
import { actions } from "astro:actions";

const result = Astro.getActionResult(actions.subscribe);
const currentYear = new Date().getFullYear();
---

<footer>
  {result?.data && <script is:inline>alert("Thank you! You successfully subscribed to our newsletter!"); window.location.href = window.location.pathname;</script>}
  {result?.error && <script is:inline>alert("Something went wrong. Please try again later."); window.location.href = window.location.pathname;</script>}
  <div class="footer-content">
    <div class="footer-section">
      <h4>HABITAT</h4>
      <p class="footer-description">Sustainable tourism in Salinas de Guaranda.</p>
      <div class="footer-social">
        <a href="#" aria-label="Facebook">f</a>
        <a href="#" aria-label="Twitter">🐦</a>
        <a href="#" aria-label="Instagram">📷</a>
      </div>
    </div>

    <div class="footer-section">
      <h4>Experiences</h4>
      <ul>
        <li><a href="/experiences">Natural Wonders</a></li>
        <li><a href="/experiences">Cultural Immersion</a></li>
        <li><a href="/experiences">Gastronomic</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Company</h4>
      <ul>
        <li><a href="/about">About Salinas</a></li>
        <li><a href="#">Impact Report</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Newsletter</h4>
      <form class="newsletter-form" method="POST" action={actions.subscribe}>
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          class="newsletter-input"
          required
        />
        <button type="submit" class="btn newsletter-btn">Join</button>
      </form>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} Habitat Travel. All rights reserved.</p>
    <div class="footer-bottom-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--light-gray);
    color: var(--black);
    padding: 3rem 2rem 1rem;
  }

  footer a {
    color: var(--black);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  footer a:hover {
    color: var(--medium-gray);
  }

  .footer-content {
    max-width: 1600px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .footer-section {
    padding: 0 1rem;
  }

  .footer-section h4 {
    margin: 0 0 1rem 0;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-dark);
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--medium-gray);
    border-radius: 50%;
    transition: background 0.3s;
    font-size: 1rem;
  }

  .footer-social a:hover {
    background: var(--primary);
  }

  .footer-section input {
    padding: 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .footer-description {
    font-size: 0.85rem;
    margin: 0 0 1rem 0;
    line-height: 1.5;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem;
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .newsletter-btn {
    margin: 0;
    white-space: nowrap;
  }

  .footer-bottom {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    padding-top: 2rem;
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    gap: 1rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-bottom-links {
    display: flex;
    gap: 2rem;
  }

  .footer-bottom a {
    text-decoration: none;
    transition: color 0.3s;
    font-size: 0.85rem;
  }

  .footer-bottom a:hover {
    color: var(--accent-purple);
  }

  @media (max-width: 1024px) {
    footer {
      padding: 2rem 1.5rem 0.75rem;
    }

    .footer-content {
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .footer-section {
      padding: 0 0.75rem;
    }

    .footer-section h4 {
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }

    .footer-description {
      font-size: 0.8rem;
    }

    .newsletter-input {
      min-width: 150px;
      font-size: 0.8rem;
    }

    .footer-bottom {
      padding-top: 1.5rem;
      font-size: 0.8rem;
    }

    .footer-bottom-links {
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 2rem 1rem 0.75rem;
    }

    .footer-content {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .footer-section {
      padding: 0;
    }

    .footer-section h4 {
      font-size: 0.85rem;
      margin-bottom: 0.6rem;
    }

    .footer-section li {
      margin-bottom: 0.4rem;
    }

    .footer-description {
      font-size: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .footer-social {
      gap: 0.75rem;
    }

    .footer-social a {
      width: 36px;
      height: 36px;
      font-size: 0.9rem;
    }

    footer a {
      font-size: 0.8rem;
    }

    .newsletter-form {
      gap: 0.35rem;
    }

    .newsletter-input {
      min-width: 120px;
      padding: 0.4rem;
      font-size: 0.75rem;
    }

    .newsletter-btn {
      padding: 0.4rem 0.75rem;
      font-size: 0.75rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
      padding-top: 1rem;
    }

    .footer-bottom-links {
      gap: 1.25rem;
    }

    .footer-bottom a {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: 1rem 0.75rem 0.5rem;
    }

    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .footer-section {
      padding: 0.5rem 0.25rem;
    }

    .footer-section h4 {
      font-size: 0.75rem;
      margin-bottom: 0.35rem;
      font-weight: 700;
    }

    .footer-section li {
      margin-bottom: 0.2rem;
    }

    .footer-description {
      font-size: 0.65rem;
      margin-bottom: 0.3rem;
      line-height: 1.3;
    }

    .footer-social {
      gap: 0.35rem;
      margin-top: 0.35rem;
    }

    .footer-social a {
      width: 28px;
      height: 28px;
      font-size: 0.7rem;
      flex-shrink: 0;
    }

    footer a {
      font-size: 0.7rem;
      line-height: 1.2;
    }

    .newsletter-form {
      flex-direction: column;
      gap: 0.2rem;
    }

    .newsletter-input {
      width: 100%;
      min-width: unset;
      padding: 0.3rem 0.35rem;
      font-size: 0.65rem;
      height: 28px;
    }

    .newsletter-btn {
      width: 100%;
      padding: 0.3rem 0.35rem;
      font-size: 0.65rem;
      height: 28px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.3rem;
      padding-top: 0.5rem;
    }

    .footer-bottom p {
      font-size: 0.65rem;
      line-height: 1.2;
    }

    .footer-bottom-links {
      gap: 0.5rem;
      justify-content: center;
    }

    .footer-bottom a {
      font-size: 0.6rem;
    }
  }
</style>
