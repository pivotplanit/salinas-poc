---
import Button from "../Button.astro";

interface Props {
  title: string;
  duration: string;
  groupSize: string;
  description: string;
  highlights: string[];
  price: string;
}

const { title, duration, groupSize, description, highlights, price } = Astro.props;
---

<div class="itinerary-card">
  <div class="card-header">
    <h3>{title}</h3>
    <div class="card-meta">
      <span class="meta-item">
        <span class="meta-icon">⏱️</span>
        {duration}
      </span>
      <span class="meta-item">
        <span class="meta-icon">👥</span>
        {groupSize}
      </span>
    </div>
  </div>

  <p class="card-description">{description}</p>

  <div class="highlights">
    <h4>Highlights:</h4>
    <ul>
      {highlights.map((highlight) => (
        <li>{highlight}</li>
      ))}
    </ul>
  </div>

  <div class="card-footer">
    <div class="price">{price}</div>
    <Button 
      text="View Details"
      href="#"
      variant="primary"
      size="md"
    />
  </div>
</div>

<style>
  .itinerary-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 300ms ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .itinerary-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-8px);
    border-color: #2D5016;
  }

  .card-header {
    padding: 2rem;
    background: linear-gradient(135deg, #f9f9f9 0%, #efefef 100%);
    border-bottom: 2px solid #2D5016;
  }

  .card-header h3 {
    margin: 0 0 1rem 0;
    font-size: 1.4rem;
    color: #2D5016;
    font-weight: 600;
  }

  .card-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.95rem;
    color: #666;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-icon {
    font-size: 1.1rem;
  }

  .card-description {
    padding: 1.5rem 2rem 0;
    color: #666;
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0;
  }

  .highlights {
    padding: 1.5rem 2rem;
    flex: 1;
  }

  .highlights h4 {
    margin: 0 0 1rem 0;
    font-size: 1rem;
    color: #2D5016;
    font-weight: 600;
  }

  .highlights ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlights li {
    padding: 0.5rem 0 0.5rem 1.5rem;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
    position: relative;
  }

  .highlights li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2D5016;
    font-weight: 700;
  }

  .card-footer {
    padding: 2rem;
    border-top: 1px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #2D5016;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .card-header {
      padding: 1.5rem;
    }

    .card-header h3 {
      font-size: 1.2rem;
    }

    .card-description {
      padding: 1rem 1.5rem 0;
    }

    .highlights {
      padding: 1rem 1.5rem;
    }

    .card-footer {
      padding: 1rem 1.5rem;
      flex-direction: column;
      gap: 1rem;
    }

    .price {
      text-align: center;
      width: 100%;
    }
  }
</style>
