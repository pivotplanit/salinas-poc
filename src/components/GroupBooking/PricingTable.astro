---
import { pricingTable } from "../../lib/group-booking-data";
---

<section class="pricing-section">
  <div class="container">
    <h2>Group Pricing</h2>
    <p class="section-subtitle">Transparent pricing with group discounts</p>

    <div class="pricing-table-wrapper">
      <table class="pricing-table">
        <thead>
          <tr>
            <th>Group Size</th>
            <th>2-Day Trip</th>
            <th>3-Day Trip</th>
            <th>5-Day Trip</th>
          </tr>
        </thead>
        <tbody>
          {pricingTable.map((row) => (
            <tr>
              <td class="group-size">{row.groupSize}</td>
              <td>{row.twoDay}</td>
              <td>{row.threeDay}</td>
              <td>{row.fiveDay}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="pricing-notes">
      <h3>What's Included</h3>
      <ul>
        <li>Expert guides and transportation</li>
        <li>All meals (breakfast, lunch, dinner)</li>
        <li>Accommodation at selected properties</li>
        <li>All activity materials and equipment</li>
        <li>Entrance fees to attractions</li>
        <li>24/7 emergency support</li>
      </ul>

      <p class="pricing-disclaimer">
        Prices are per person in USD. Group discounts increase with group size. Custom itineraries and longer trips available at negotiated rates. Prices valid for 30 days from quote date.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 4rem 1rem;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2D5016;
    margin: 0 0 0.5rem 0;
    text-align: center;
  }

  .section-subtitle {
    text-align: center;
    color: #666;
    font-size: 1.1rem;
    margin: 0 0 2rem 0;
  }

  .pricing-table-wrapper {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    margin-bottom: 3rem;
    border: 1px solid #e0e0e0;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
  }

  .pricing-table thead {
    background: linear-gradient(135deg, #2D5016 0%, #1f3610 100%);
    color: white;
  }

  .pricing-table th {
    padding: 1.5rem;
    text-align: left;
    font-weight: 600;
    font-size: 1rem;
  }

  .pricing-table td {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e0e0e0;
    font-size: 0.95rem;
  }

  .pricing-table tbody tr:last-child td {
    border-bottom: none;
  }

  .pricing-table tbody tr:hover {
    background: #f9f9f9;
  }

  .group-size {
    font-weight: 600;
    color: #2D5016;
  }

  .pricing-table td {
    text-align: center;
    font-weight: 600;
    color: #2D5016;
  }

  .pricing-table td:first-child {
    text-align: left;
  }

  .pricing-notes {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #e0e0e0;
  }

  .pricing-notes h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2rem;
    color: #2D5016;
    font-weight: 600;
  }

  .pricing-notes ul {
    list-style: none;
    margin: 0 0 1.5rem 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .pricing-notes li {
    padding: 0 0 0 1.75rem;
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    position: relative;
  }

  .pricing-notes li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2D5016;
    font-weight: 700;
  }

  .pricing-disclaimer {
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid #e0e0e0;
    color: #999;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 3rem 1rem;
    }

    h2 {
      font-size: 2rem;
    }

    .pricing-table th,
    .pricing-table td {
      padding: 1rem;
      font-size: 0.85rem;
    }

    .pricing-table th {
      font-size: 0.85rem;
    }

    .pricing-notes {
      padding: 1.5rem;
    }

    .pricing-notes ul {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .pricing-table-wrapper {
      overflow-x: auto;
    }

    .pricing-table {
      min-width: 100%;
      font-size: 0.75rem;
    }

    .pricing-table th,
    .pricing-table td {
      padding: 0.75rem;
    }
  }
</style>
