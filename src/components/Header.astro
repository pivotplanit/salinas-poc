---
interface NavLink {
  href: string;
  label: string;
  id: string;
}

const navLinks: NavLink[] = [
  { href: "/", label: "Home", id: "home" },
  { href: "/experiences", label: "Experiences Catalog", id: "experiences" },
  { href: "/experiences/detail", label: "Experience Detail", id: "detail" },
  { href: "/group-booking", label: "Group Booking", id: "booking" },
  { href: "/about", label: "About", id: "about" },
  { href: "/practical-info", label: "Practical Info", id: "info" },
];

const currentPath = Astro.url.pathname;
const currentPage = currentPath === "/" ? "home" : currentPath.replace("/", "").split("/")[0];
---

<header>
  <div class="header-content">
    <a href="/" class="logo">HABITAT</a>
    <nav>
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-page={link.id}
          class={currentPage === link.id ? 'active' : ''}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <button class="btn">Book Now</button>
  </div>
</header>

<script>
  // Set active nav based on current page
  function setActiveNav() {
    const path = window.location.pathname;
    const page = path === '/' ? 'home' : path.replace('/', '').split('/')[0];
    document.querySelectorAll('nav a[data-page]').forEach((link) => {
      if (link.getAttribute('data-page') === page) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  setActiveNav();
  window.addEventListener('load', setActiveNav);
</script>
