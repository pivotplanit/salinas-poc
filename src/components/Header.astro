---
import { getRelativeLocaleUrl } from "astro:i18n";

const { locale = "en" } = Astro.params;
interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = [
  { href: "/", label: "Home" },
  { href: "/experiences/", label: "Experiences Catalog" },
  { href: "/group-booking/", label: "Group Booking" },
  { href: "/about/", label: "About" },
  { href: "/practical-info/", label: "Practical Info" },
];

const currentPath = Astro.url.pathname;
const currentLocale = Astro.currentLocale || "en";
const currentPage = currentPath.replace(`/${currentLocale}`, "");

const getPageId = (href: string): string => {
  return href.replace("/", "").split("/")[0];
};

const getLocalizedHref = (href: string): string => {
  return `${getRelativeLocaleUrl(locale, href)}`;
};
---

<header>
  <div class="header-content">
    <a href={getLocalizedHref("/")} class="logo">HABITAT</a>
    <button class="menu-toggle" aria-label="Toggle menu">☰</button>
    <nav>
      {navLinks.map((link) => (
        <a
          href={getLocalizedHref(link.href)}
          class={link.href === currentPage ? 'active' : ''}
          aria-disabled={link.href === currentPage}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="header-actions">
      <div class="locale-switcher">
        <select id="locale-select" class="locale-select" data-current-page={currentPage}>
          <option value="en" selected={currentLocale === "en"} onclick="">English</option>
          <option value="es" selected={currentLocale === "es"}>Español</option>
        </select>
      </div>
      <button class="btn">Book Now</button>
    </div>
  </div>
</header>

<script>
  // Type guard to ensure element is HTMLElement
  function isHTMLElement(el: Element | null): el is HTMLElement {
    return el instanceof HTMLElement;
  }

  // Mobile menu toggle
  function setupMobileMenu() {
    const menuToggleEl = document.querySelector('.menu-toggle');
    const navEl = document.querySelector('nav');
    
    // Type guard narrows types naturally
    if (!isHTMLElement(menuToggleEl) || !isHTMLElement(navEl)) return;

    menuToggleEl.addEventListener('click', (e) => {
      e.stopPropagation();
      navEl.classList.toggle('open');
      menuToggleEl.classList.toggle('open');
    });

    // Close menu when clicking a link
    navEl.querySelectorAll('a').forEach((link) => {
      // HTMLElement guaranteed by DOM API
      if (link instanceof HTMLElement) {
        link.addEventListener('click', () => {
          navEl.classList.remove('open');
          menuToggleEl.classList.remove('open');
        });
      }
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const headerEl = document.querySelector('header');
      if (!isHTMLElement(headerEl) || !(e.target instanceof Node)) return;
      
      if (!headerEl.contains(e.target)) {
        navEl.classList.remove('open');
        menuToggleEl.classList.remove('open');
      }
    });
  }

  // Locale switcher
  function setupLocaleSwitcher() {

    const localeSelect = document.getElementById('locale-select')
    if (!localeSelect) return;
    const currentPage = localeSelect.dataset.currentPage || '/';

    localeSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const locale = target.value;

      window.location.href = `/${locale}${currentPage}`;
    });
  }

  // Call on page load
  function init() {
    setupMobileMenu();
    setupLocaleSwitcher();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  header {
    background: var(--white);
    padding: 0.9rem 2rem;
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }

  nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  nav a {
    font-size: 0.85rem;
    color: var(--text-dark);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
    white-space: nowrap;
  }

  nav a:hover,
  nav a.active {
    color: var(--medium-gray);
  }

  nav a.active {
    pointer-events: none;
  }



  .header-actions {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .locale-switcher {
    display: flex;
    align-items: center;
  }

  .locale-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: white;
    color: var(--text-dark);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.3s, box-shadow 0.3s;
    min-width: 140px;
  }

  .locale-select:hover {
    border-color: var(--primary);
  }

  .locale-select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(55, 65, 81, 0.1);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    padding: 0.5rem;
    color: var(--text-dark);
    transition: color 0.3s;
  }

  .menu-toggle:hover {
    color: var(--accent-purple);
  }

  @media (max-width: 1024px) {
    header {
      padding: 0.8rem 1.5rem;
    }

    .header-content {
      gap: 1rem;
    }

    nav {
      gap: 2rem;
    }

    nav a {
      font-size: 0.8rem;
    }

    .header-actions {
      gap: 1rem;
    }

    .locale-select {
      font-size: 0.8rem;
      padding: 0.4rem 0.6rem;
      min-width: 120px;
    }

    .btn {
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    header {
      padding: 0.75rem 1rem;
    }

    .header-content {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .logo {
      font-size: 0.85rem;
    }

    .menu-toggle {
      display: block;
    }

    nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      flex-direction: column;
      gap: 0;
      padding: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      border-bottom: 1px solid var(--border-color);
    }

    nav.open {
      max-height: 500px;
      padding: 1rem;
    }

    nav a {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      border-bottom: 1px solid var(--very-light-gray);
      display: block;
    }

    nav a:last-child {
      border-bottom: none;
    }

    .header-actions {
      flex-wrap: wrap;
      gap: 1rem;
      width: 100%;
      justify-content: space-between;
      margin-top: 0.5rem;
      order: 3;
    }

    .locale-select {
      font-size: 0.85rem;
      padding: 0.45rem 0.65rem;
      min-width: 130px;
    }

    .btn {
      padding: 0.5rem 1rem;
      font-size: 0.8rem;
      width: auto;
    }
  }

  @media (max-width: 480px) {
    header {
      padding: 0.6rem 0.75rem;
    }

    .header-content {
      gap: 0.25rem;
    }

    .logo {
      font-size: 0.75rem;
      flex: 1;
    }

    .menu-toggle {
      font-size: 1.25rem;
      padding: 0.4rem;
    }

    nav {
      top: calc(100% + 1px);
    }

    nav a {
      padding: 0.6rem 0.75rem;
      font-size: 0.85rem;
    }

    .btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
      border-radius: 2px;
    }
  }
</style>
