---
import IconRenderer from "../IconRenderer.astro";
import Button from "../Button.astro";

// Poster shown while the video downloads (and as a fallback when autoplay is blocked
// or the user prefers reduced motion). Swap to your real asset when ready.
const heroPoster = "https://assets.habitattraveltours.com/images/salinas-eagle-view.jpg";

// Accent hero background video. Replace with the final asset URL(s).
// Recommended: muted, ~10-20s loop, 1080p, no audio track, <8MB.
const heroVideoMp4 = "https://assets.habitattraveltours.com/videos/salinas-home-video.mp4";
// const heroVideoWebm = "https://assets.habitattraveltours.com/videos/salinas-accent-hero.webm";
---

<section class="accent-hero" id="home">
  <video
    class="accent-hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={heroPoster}
    aria-hidden="true"
    tabindex="-1"
  >
    <!-- <source src={heroVideoWebm} type="video/webm" /> -->
    <source src={heroVideoMp4} type="video/mp4" />
  </video>
  <div class="accent-hero-overlay" aria-hidden="true"></div>
  <div class="accent-hero-content">
    <h1>Experience Salinas from<br />Above</h1>
    <p>
      Take a breathtaking aerial journey over our community, the majestic
      Chimborazo, and the stunning Andean landscapes that we call home.
    </p>
  </div>
</section>

<style define:vars={{ heroPoster: `url(${heroPoster})` }}>
  .accent-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Fallback shown if the <video> element is removed or fails to load */
    background-image: var(--heroPoster);
    background-size: cover;
    background-position: center;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    min-height: 500px;
  }

  .accent-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    pointer-events: none;
  }

  .accent-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(0, 0, 0, 0.35);
  }

  /* Respect users who opt out of motion: hide the video and show the poster */
  @media (prefers-reduced-motion: reduce) {
    .accent-hero-video {
      display: none;
    }
  }

  .accent-hero-content {
    position: relative;
    z-index: 1;
    color: white;
    background: transparent;
    margin: 0 auto;
    border: 2px solid transparent;
    border-radius: 4px;
    padding: 2rem 3rem;
    max-width: 768px;
    width: 100%;
  }

  .accent-hero-content h1 {
    font-size: 2.5rem;
    margin: 0 0 1.5rem 0;
    font-weight: 700;
  }

  .accent-hero p {
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 1024px) {
    .accent-hero-content {
      padding: 2rem 4rem;
    }

    .accent-hero-content h1 {
      font-size: 2.1rem;
    }
  }

  @media (max-width: 768px) {
    .accent-hero {
      padding: 2rem 1rem;
      min-height: 400px;
    }

    .accent-hero-content {
      padding: 1.5rem 2rem;
    }

    .accent-hero-content h1 {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }

    .accent-hero p {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .accent-hero {
      padding: 1rem 0.75rem;
      min-height: 350px;
    }

    .accent-hero-content {
      padding: 1rem 1.5rem;
      border-radius: 2px;
      border-width: 1px;
    }

    .accent-hero-content h1 {
      font-size: 1.4rem;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .accent-hero p {
      font-size: 0.8rem;
    }
  }
</style>
