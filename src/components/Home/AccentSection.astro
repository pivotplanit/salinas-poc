---
import IconRenderer from "@components/IconRenderer.astro";
interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  featureText?: string;
}

const { title, description, buttonText, buttonHref, featureText } = Astro.props;
---

<section class="cta-dark" id="booking">
  <div class="section-container cta-dark-content">
    <div class="cta-text">
      <h2>{title}</h2>
      <p>{description}</p>
      {
        featureText && (
          <div class="cta-feature">
            <div class="cta-feature-icon">
              <IconRenderer icon="ShieldCheck" />
            </div>
            <div class="cta-feature-text">{featureText}</div>
          </div>
        )
      }
    </div>
    <div class="cta-button">
      <a href={buttonHref} class="btn btn-outline">{buttonText}</a>
    </div>
  </div>
</section>

<style>
  .cta-dark {
    background-image:
      linear-gradient(#1B3A5CD9, #1B3A5CD9),
      url('https://assets.habitattraveltours.com/images/salinas-home-uni-trip.jpg');
    background-size: cover;
    background-position: center;
    color: var(--white);
    padding: 8rem 2rem;
  }

  .cta-dark-content {
    margin: 0 auto;
    display: grid;
    grid-template-columns: fit-content(70ch) 1fr;
    gap: 3rem;
    align-items: center;
    border: 1px solid white;
    border-radius: 8px;
    background-color: #0f2a424d;
    padding: 3rem;
  }

  .cta-text h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .cta-text p {
    margin-bottom: 2rem;
    line-height: 1.6;
    font-size: 1rem;
  }

  .cta-feature {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-feature > :global(.cta-feature-icon) {
    color: #6b9b37;
    background: #ffffff1a;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .cta-feature-text {
    color: var(--white);
    font-size: 0.7rem;
  }

  .cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
  }

  .btn {
    font-weight: 700;
  }

  .btn-outline {
    border: 2px solid var(--white);
    background: var(--white);
    color: var(--primary);
    padding: 0.75rem 2rem;
  }

  .btn-outline:hover {
    background: var(--primary);
    color: var(--white);
  }

  @media (max-width: 1024px) {
    .cta-dark {
      padding: 5rem 1.5rem;
    }

    .cta-dark-content {
      gap: 2rem;
    }

    .cta-text h2 {
      font-size: 1.75rem;
    }

    .cta-text p {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .cta-dark {
      padding: 3rem 1rem;
    }

    .cta-dark-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cta-text h2 {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .cta-text p {
      font-size: 0.9rem;
      margin-bottom: 1.25rem;
    }

    .cta-feature {
      gap: 0.75rem;
    }

    .cta-feature-text {
      font-size: 0.85rem;
    }

    .cta-button {
      justify-content: flex-start;
    }

    .btn-outline {
      padding: 0.65rem 1.5rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .cta-dark {
      padding: 2rem 0.75rem;
    }

    .cta-dark-content {
      gap: 1rem;
    }

    .cta-text h2 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
    }

    .cta-text p {
      font-size: 0.85rem;
      margin-bottom: 1rem;
      line-height: 1.5;
    }

    .cta-feature {
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .cta-feature-icon {
      font-size: 0.9rem;
      margin-top: 0.15rem;
    }

    .cta-feature-text {
      font-size: 0.75rem;
    }

    .cta-button {
      width: 100%;
    }

    .btn-outline {
      width: 100%;
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>
