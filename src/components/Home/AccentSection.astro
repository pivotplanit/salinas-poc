---
interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  featureText?: string;
}

const { title, description, buttonText, buttonHref, featureText } = Astro.props;
---

<section class="cta-dark" id="booking">
  <div class="cta-dark-content">
    <div class="cta-text">
      <h2>{title}</h2>
      <p>{description}</p>
      {featureText && (
        <div class="cta-feature">
          <span class="cta-feature-icon">✓</span>
          <div class="cta-feature-text">{featureText}</div>
        </div>
      )}
    </div>
    <div class="cta-button">
      <a href={buttonHref} class="btn btn-outline">{buttonText}</a>
    </div>
  </div>
</section>

<style>
  .cta-dark {
    background: var(--primary);
    color: var(--white);
    padding: 8rem 2rem;
  }

  .cta-dark-content {
    max-width: 1600px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: fit-content(70ch) 1fr;
    gap: 3rem;
    align-items: center;
  }

  .cta-text h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .cta-text p {
    margin-bottom: 2rem;
    line-height: 1.6;
    font-size: 1rem;
  }

  .cta-feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .cta-feature-icon {
    color: var(--accent-purple);
    font-size: 1rem;
    font-weight: bold;
    flex-shrink: 0;
  }

  .cta-feature-text {
    color: var(--white);
    font-size: 0.95rem;
  }

  .cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-outline {
    border: 2px solid var(--white);
    background: transparent;
    color: var(--white);
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }

  .btn-outline:hover {
    background: var(--white);
    color: var(--dark-navy);
  }

  @media (max-width: 1024px) {
    .cta-dark {
      padding: 5rem 1.5rem;
    }

    .cta-dark-content {
      gap: 2rem;
    }

    .cta-text h2 {
      font-size: 1.75rem;
    }

    .cta-text p {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .cta-dark {
      padding: 3rem 1rem;
    }

    .cta-dark-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cta-text h2 {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .cta-text p {
      font-size: 0.9rem;
      margin-bottom: 1.25rem;
    }

    .cta-feature {
      gap: 0.75rem;
    }

    .cta-feature-text {
      font-size: 0.85rem;
    }

    .cta-button {
      justify-content: flex-start;
    }

    .btn-outline {
      padding: 0.65rem 1.5rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .cta-dark {
      padding: 2rem 0.75rem;
    }

    .cta-dark-content {
      gap: 1rem;
    }

    .cta-text h2 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
    }

    .cta-text p {
      font-size: 0.85rem;
      margin-bottom: 1rem;
      line-height: 1.5;
    }

    .cta-feature {
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .cta-feature-icon {
      font-size: 0.9rem;
      margin-top: 0.15rem;
    }

    .cta-feature-text {
      font-size: 0.75rem;
    }

    .cta-button {
      width: 100%;
    }

    .btn-outline {
      width: 100%;
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>
