---
import { Image } from "astro:assets";
import IconRenderer from "../IconRenderer.astro";

interface Category {
  id: string;
  icon: string;
  title: string;
  description: string;
  href: string;
  image?: string;
  isNew?: boolean;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;

// Reliable placeholder images from picsum.photos
const imagePlaceholders: Record<string, string> = {
  "natural-wonders": "https://picsum.photos/400/300?random=1",
  "cultural-immersion": "https://picsum.photos/400/300?random=2",
  gastronomic: "https://picsum.photos/400/300?random=3",
  "multi-day": "https://picsum.photos/400/300?random=4",
};
---

<section class="experience-categories" id="catalog">
  <div class="section-container">
    <h2 class="section-title">Experience Categories</h2>
    <div class="categories-grid">
      {categories.map((cat) => (
        <div class="category-card">
          <div class="card-badge" class:list={cat.isNew ? "new" : ""}>
            {cat.isNew && <span class="new-label">NEW LABEL</span>}
          </div>
          <div class="card-content">
            <div class="card-image">
              <img 
                src={cat.image || imagePlaceholders[cat.id] || imagePlaceholders["natural-wonders"]}
                alt={cat.title}
                class="category-image"
                loading="lazy"
                decoding="async"
                width="400"
                height="300"
              />
            </div>
            <div class="card-text">
              <div class="card-header">
                <span class="category-icon">
                  <IconRenderer icon={cat.icon} size={24} />
                </span>
                <h3>{cat.title}</h3>
              </div>
              <p class="card-description">{cat.description}</p>
              <a href={cat.href} class="explore-link">Explore <span>→</span></a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>


  .section-container {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
  }

  .section-title {
    font-size: 2.5rem;
    color: var(--text-dark);
    margin-bottom: 2rem;
    font-weight: 700;
    text-align: left;
  }

  .experience-categories {
    padding: 4rem 2rem;
    background: var(--white);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(600px, 1fr));
    gap: 2rem;
  }

  .category-card {
    position: relative;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    background: var(--white);
    min-height: 250px;
  }

  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
  }

  .card-badge.new .new-label {
    background: var(--accent-purple);
    color: var(--white);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-content {
    display: flex;
    width: 100%;
    gap: 1rem;
  }

  .card-image {
    flex: 0 0 32%;
    background: var(--very-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    aspect-ratio: 4 / 3;
  }

  .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .category-icon {
    flex-shrink: 0;
    color: var(--text-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .card-header h3 {
    font-size: 1.15rem;
    margin: 0;
    color: var(--text-dark);
    font-weight: 600;
    line-height: 1.3;
  }

  .card-description {
    color: var(--text-medium);
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-size: 0.9rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .explore-link {
    color: var(--accent-purple);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
    width: fit-content;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .explore-link:hover {
    color: #7d3c98;
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 1.5rem;
    }

    .experience-categories {
      padding: 3rem 1.5rem;
    }

    .section-title {
      font-size: 2.2rem;
    }
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .experience-categories {
      padding: 2rem 1rem;
    }

    .card-content {
      flex-direction: column;
      gap: 0;
    }

    .card-image {
      flex: 1;
      min-height: 150px;
    }

    .card-header {
      margin-bottom: 0.75rem;
    }

    .card-description {
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
    }

    .category-card {
      min-height: auto;
    }
  }

  @media (max-width: 480px) {
    .categories-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .experience-categories {
      padding: 1.5rem 0.75rem;
    }

    .section-title {
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .card-content {
      padding: 1rem;
    }

    .card-image {
      min-height: 120px;
      padding: 0.75rem;
    }

    .card-header h3 {
      font-size: 1rem;
    }

    .category-icon {
      font-size: 1.2rem;
    }

    .card-description {
      font-size: 0.8rem;
      margin-bottom: 0.75rem;
    }

    .explore-link {
      font-size: 0.85rem;
    }
  }
</style>
