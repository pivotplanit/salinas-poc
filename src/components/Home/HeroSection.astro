---
import IconRenderer from "../IconRenderer.astro";
import Button from "../Button.astro";

const heroImage = "https://assets.habitattraveltours.com/images/salinas-hometown.jpg";
---

<script>
  function setHeroHeight() {
    const header = document.querySelector('header');
    const hero = document.getElementById('home');    
    if (header && hero) {
      const headerHeight = header.offsetHeight;
      
      hero.style.height = `calc(100vh - ${headerHeight}px)`;
    }
  }

  // Set on load
  setHeroHeight();

  // Recalculate on resize (for responsive changes)
  window.addEventListener('resize', setHeroHeight);
</script>

<section class="hero" id="home">
  <div class="hero-content">
    <h1>Discover Ecuador's<br>Community-Run Mountain</h1>
    <p>Where tourism supports 40+ local families and traditions</p>
    <div class="hero-buttons">
      <Button class="btn">Plan Your Group Experience</Button>
      <Button class="btn btn-outline">Explore Experiences</Button>
    </div>
    <div class="hero-info">
      <span class="hero-info-icon"><IconRenderer icon={"ShieldCheck"} size={16}/></span>
      <p>UNESCO-Recognized Sustainable Tourism</p>
    </div>
  </div>
</section>

<style define:vars={{ heroBg: `${heroImage}` }}>
  .hero {
    background-image: url('https://assets.habitattraveltours.com/images/salinas-eagle-view.jpg');
    background-size: cover;
    background-position: center;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-content {
    color: var(--primary);
    background: var(--white);
    margin: 0 auto;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    padding: 2rem 6rem;
    max-width: 600px;
    width: 100%;
  }

  .hero-content h1 {
    font-size: 2.4rem;
    margin: 0 0 1.5rem 0;
    font-weight: 700;
  }

  .hero p {
    font-size: 1rem;
    margin-bottom: 2rem;
    opacity: 0.95;
  }

  .hero-info {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
  }

  .hero-info p {
    font-size: 0.75rem;
    opacity: 0.85;
    margin: 0;
  }

  .hero-info span {
    margin-right: 0;
    flex-shrink: 0;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .hero-content {
      padding: 2rem 4rem;
    }

    .hero-content h1 {
      font-size: 2.1rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 1rem;
      min-height: 400px;
    }

    .hero-content {
      padding: 1.5rem 2rem;
    }

    .hero-content h1 {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }

    .hero p {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .hero-buttons {
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .btn {
      width: 100%;
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
    }

    .hero-info {
      font-size: 0.7rem;
    }

    .hero-info p {
      font-size: 0.65rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 1rem 0.75rem;
      min-height: 350px;
    }

    .hero-content {
      padding: 1rem 1.5rem;
      border-radius: 2px;
      border-width: 1px;
    }

    .hero-content h1 {
      font-size: 1.4rem;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .hero p {
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }

    .hero-buttons {
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .btn {
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
    }
  }
</style>
