---
import { Image } from "astro:assets";

interface Props {
  testimonials: Array<{
    avatar: string;
    name: string;
    affiliation: string;
    date: string;
    rating: number;
    text: string;
  }>;
}

const { testimonials = [] } = Astro.props;
---

<section class="testimonials">
  <div class="section-container">
    <h2 class="section-title">What Visitors Say</h2>
    <div class="testimonials-grid">
      {testimonials && testimonials.length > 0 ? (
        testimonials.map(testimonial => (
          <div class="testimonial-card">
            <div class="testimonial-header">
              <Image src={testimonial.avatar} alt={testimonial.name} class="testimonial-avatar" width={100} height={100} />
              <div class="testimonial-info">
                <h4>{testimonial.name}</h4>
                <p class="testimonial-affiliation">{testimonial.affiliation}</p>
                <p class="testimonial-date">{testimonial.date}</p>
              </div>
            </div>
            <div class="testimonial-stars">{"★".repeat(testimonial.rating)}</div>
            <p class="testimonial-text">
              "{testimonial.text}"
            </p>
          </div>
        ))
      ) : (
        <div class="empty-state">
          <p>No testimonials available at this time</p>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .section-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .section-title {
    font-size: 2.5rem;
    color: var(--text-dark);
    margin-bottom: 2rem;
    font-weight: 700;
    text-align: center;
  }

  .testimonials {
    padding: 4rem 2rem;
    background: var(--very-light-gray);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .testimonial-header {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    align-items: flex-start;
  }

  .testimonial-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial-info h4 {
    margin: 0;
    color: var(--text-dark);
    font-size: 1rem;
    font-weight: 600;
  }

  .testimonial-affiliation {
    margin: 0.25rem 0 0 0;
    color: var(--text-light);
    font-size: 0.85rem;
  }

  .testimonial-date {
    margin: 0.15rem 0 0 0;
    color: var(--text-light);
    font-size: 0.8rem;
  }

  .testimonial-stars {
    color: #000;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .testimonial-text {
    color: var(--text-medium);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Empty States */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 2rem;
    color: var(--text-medium);
  }

  @media (max-width: 1024px) {
    .testimonials {
      padding: 3rem 1.5rem;
    }

    .section-container {
      padding: 0 1.5rem;
    }

    .section-title {
      font-size: 2.2rem;
      margin-bottom: 1.5rem;
    }

    .testimonials-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .testimonial-card {
      padding: 1.5rem;
    }

    .testimonial-avatar {
      width: 80px;
      height: 80px;
    }

    .testimonial-info h4 {
      font-size: 0.95rem;
    }

    .testimonial-affiliation {
      font-size: 0.8rem;
    }

    .testimonial-stars {
      font-size: 1.25rem;
      margin-bottom: 0.75rem;
    }

    .testimonial-text {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 768px) {
    .testimonials {
      padding: 2rem 1rem;
    }

    .section-container {
      padding: 0 1rem;
    }

    .section-title {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .testimonial-card {
      padding: 1.25rem;
    }

    .testimonial-header {
      gap: 0.75rem;
    }

    .testimonial-avatar {
      width: 70px;
      height: 70px;
    }

    .testimonial-info h4 {
      font-size: 0.9rem;
    }

    .testimonial-affiliation {
      font-size: 0.75rem;
    }

    .testimonial-date {
      font-size: 0.7rem;
    }

    .testimonial-stars {
      font-size: 1.2rem;
    }

    .testimonial-text {
      font-size: 0.85rem;
      line-height: 1.5;
    }
  }

  @media (max-width: 480px) {
    .testimonials {
      padding: 1.5rem 0.75rem;
    }

    .section-container {
      padding: 0 0.75rem;
    }

    .section-title {
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .testimonial-card {
      padding: 1rem;
      border-radius: 6px;
    }

    .testimonial-header {
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .testimonial-avatar {
      width: 60px;
      height: 60px;
    }

    .testimonial-info h4 {
      font-size: 0.85rem;
      margin: 0 0 0.15rem 0;
    }

    .testimonial-affiliation {
      font-size: 0.7rem;
      margin: 0.1rem 0 0 0;
    }

    .testimonial-date {
      font-size: 0.65rem;
      margin: 0.05rem 0 0 0;
    }

    .testimonial-stars {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .testimonial-text {
      font-size: 0.8rem;
      line-height: 1.4;
    }
  }
</style>
