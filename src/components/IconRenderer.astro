---
// Compatibility wrapper around astro-icon (Lucide).
// Existing call sites use PascalCase names like `CheckCircle`; we map them
// to Lucide's kebab-case names so consumers don't need to change.
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  size?: number;
  color?: string;
  class?: string;
}

const { icon, size = 20, color, class: className } = Astro.props;

// PascalCase (legacy) -> Lucide kebab-case
const lucideNameMap: Record<string, string> = {
  CheckCircle: "circle-check",
  Medal: "medal",
  Sun: "sun",
  TriangleCaution: "triangle-alert",
  Calendar: "calendar",
  Leaf: "leaf",
  Palette: "palette",
  UtensilsCrossed: "utensils-crossed",
  Backpack: "backpack",
  Factory: "factory",
  Pickaxe: "pickaxe",
  HeartHandshake: "heart-handshake",
  Users: "users",
  Lock: "lock",
  BookOpen: "book-open",
  ShieldCheck: "shield-check",
  Mountain: "mountain",
  Utensils: "utensils",
  ArrowRight: "arrow-right",
  Clock: "clock",
  Phone: "phone",
  Mail: "mail",
  Share: "share-2",
  Briefcase: "briefcase",
  Bed: "bed-double",
  ShoppingBag: "shopping-bag",
  Star: "star",
  Heart: "heart",
  Compass: "compass",
  MapPin: "map-pin",
  Map: "map",
  Globe: "globe",
  // Lucide doesn't ship the WhatsApp brand mark; closest neutral match.
  WhatsApp: "message-circle",
};

// Allow callers to also pass a raw lucide name like "circle-check" directly.
const lucideName = lucideNameMap[icon] ?? icon;
---

<Icon
  name={`lucide:${lucideName}`}
  width={size}
  height={size}
  style={color ? `color: ${color};` : undefined}
  class:list={["icon", className]}
/>
