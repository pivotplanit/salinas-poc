---
import IconRenderer from "../IconRenderer.astro";

const items = [
  "Warm jacket/fleece",
  "Sun protection (SPF 50+)",
  "Comfortable hiking boots",
  "Reusable water bottle",
  "Camera",
  "Rain jacket (waterproof)",
  "Warm hat and gloves",
  "Layers (temperature varies)",
  "Cash (limited ATMs)",
  "Personal medications",
];
---

<section class="weather-and-checklist-section">
  <div class="container">
    <div class="section-heading">
      <IconRenderer icon="Sun" size={28} />
      <h2>Weather & What to Pack</h2>
    </div>

    <div class="temp-container">
      <div class="sub-heading">
        <IconRenderer icon="Leaf" size={20} />
        <h3>Temperature</h3>
      </div>
      <div class="temp-cards">
        <div class="temp-card">
          <span class="card-label">Year-round</span>
          <span class="card-value">8-15°C</span>
          <span class="card-sub">46-59°F</span>
        </div>
        <div class="temp-card">
          <span class="card-label">Mornings</span>
          <span class="card-value">Cold</span>
          <span class="card-sub">(layers essential)</span>
        </div>
        <div class="temp-card">
          <span class="card-label">Afternoons</span>
          <span class="card-value">Moderate</span>
          <span class="card-sub">(sun protection)</span>
        </div>
      </div>
    </div>

    <div class="temp-container">
      <div class="sub-heading">
        <IconRenderer icon="Backpack" size={20} />
        <h3>Essential Items</h3>
      </div>
      <div class="checklist-grid">
        {items.map((item, i) => (
        <div class="checklist-item">
          <input
            type="checkbox"
            id={`item-${i}`}
            class="checklist-input"
          />
          <label for={`item-${i}`}>{item}</label>
        </div>
      ))}
      </div>
      
    </div>
  </div>
</section>

<style>
  .weather-and-checklist-section {
    padding: 2rem 1rem;
    background: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .section-heading h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
  }

  .sub-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .sub-heading h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
  }

  .temp-container {
    background: var(--secondary );
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1rem 0;
  }

  .temp-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .temp-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-label {
    font-size: 0.875rem;
    color: #6B7280;
  }

  .card-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
  }

  .card-sub {
    font-size: 0.875rem;
    color: #6B7280;
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .checklist-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .checklist-input {
    width: 16px;
    height: 16px;
    border: 1px solid var(--border-color);
    border-radius: 0;
    cursor: pointer;
    accent-color: var(--primary);
    flex-shrink: 0;
  }

  .checklist-item label {
    cursor: pointer;
    color: #111827;
    font-size: 0.95rem;
    user-select: none;
  }

  @media (max-width: 768px) {
    .checklist-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .temp-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
