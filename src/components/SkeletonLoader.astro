---
interface Props {
  type?: "rounded" | "rectangular" | "circle";
  width?: number | string;
  height?: number | string;
  animate?: "wave" | "pulse" | false;
  className?: string;
}

const {
  type = "rounded",
  width = "100%",
  height = "100%",
  animate = "wave",
  className = "",
} = Astro.props;

const borderRadius = type === "circle" ? "50%" : type === "rounded" ? "8px" : "0px";
const animationClass = animate ? `skeleton-${animate}` : "";
---

<div 
  class={`skeleton ${animationClass} ${className}`}
  style={{
    width: typeof width === "number" ? `${width}px` : width,
    height: typeof height === "number" ? `${height}px` : height,
    borderRadius: borderRadius,
  }}
/>

<style>
  .skeleton {
    background: linear-gradient(
      90deg,
      #f0f0f0 0%,
      #e0e0e0 50%,
      #f0f0f0 100%
    );
    background-size: 200% 100%;
  }

  .skeleton-wave {
    animation: wave 2s infinite;
  }

  .skeleton-pulse {
    animation: pulse 2s infinite;
  }

  @keyframes wave {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
</style>
