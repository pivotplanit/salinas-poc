---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterSidebar from "../../components/Experiences/FilterSidebar.astro";
import ExperiencesGrid from "../../components/Experiences/ExperiencesGrid.astro";
import Button from "../../components/Button.astro";
import experiences from "../../data/experiences.json";
import filtersData from "../../data/filters.json";
import i18nConfig from "@configs/i18n";

export function getStaticPaths() {
  return i18nConfig.locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;

const filters = filtersData.filters;
---

<BaseLayout 
  title="Experiences Catalog - Browse & Filter"
  description="Discover and filter unique experiences in Salinas de Guaranda, Ecuador"
>

  <div class="page-container">

    <div class="main-container">
      <!-- Sidebar Filters (Desktop) -->
      <FilterSidebar filters={filters} />

      <!-- Content Area -->
      <main class="content-area">
        <!-- Mobile Filter Button -->
        <div class="mobile-filter-controls">
          <button id="mobile-filter-btn" class="mobile-filter-btn">
            🔍 Filters
          </button>
          <select id="sort-select" class="sort-select">
            <option value="popular">Sort by: Most Popular</option>
            <option value="newest">Sort by: Newest</option>
            <option value="price-low">Sort by: Price (Low to High)</option>
            <option value="price-high">Sort by: Price (High to Low)</option>
          </select>
        </div>

        <!-- Results Header -->
        <div class="content-header">
          <h2>All Experiences</h2>
          <div class="header-controls">
            <span class="results-info" id="results-info">
              Showing {experiences.experiences.length} experiences
            </span>
          </div>
        </div>

        <!-- Experiences Grid -->
        <ExperiencesGrid 
          experiences={experiences.experiences}
          isLoading={false}
        />

        <!-- Load More Button -->
        <div class="load-more-section">
          <Button id="load-more-btn" variant="outline" class="load-more-btn">
            Load More Experiences
          </Button>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  // Filter state management
  const filters = {};
  let currentPage = 1;
  const itemsPerPage = 12;

  // Initialize mobile filter toggle
  function initMobileFilterToggle() {
    const mobileFilterBtn = document.getElementById("mobile-filter-btn");
    const filterSidebar = document.querySelector(".filter-sidebar");

    if (mobileFilterBtn && filterSidebar) {
      mobileFilterBtn.addEventListener("click", () => {
        filterSidebar.classList.toggle("open");
      });

      // Close sidebar when clicking outside
      document.addEventListener("click", (e) => {
        if (
          !filterSidebar.contains(e.target as Node) &&
          !mobileFilterBtn.contains(e.target as Node)
        ) {
          filterSidebar.classList.remove("open");
        }
      });
    }
  }

  // Handle load more functionality
  function initLoadMore() {
    const loadMoreBtn = document.getElementById("load-more-btn");
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        currentPage++;
        // console.log("Load more experiences");
      });
    }
  }

  // Handle sorting
  function initSorting() {
    const sortSelect = document.getElementById("sort-select");
    if (sortSelect) {
      sortSelect.addEventListener("change", (e) => {
        if (e?.target instanceof HTMLSelectElement) {
          // console.log("Sort by:", e.target.value);
        }
      });
    }
  }

  // Initialize all event listeners
  function init() {
    initMobileFilterToggle();
    initLoadMore();
    initSorting();
  }

  // Run on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  .page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  .main-container {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 2rem;
  }

  .content-area {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .mobile-filter-controls {
    display: none;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .mobile-filter-btn,
  .sort-select {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: white;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .mobile-filter-btn {
    flex: 1;
  }

  .sort-select {
    flex: 1.5;
  }

  .content-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .content-header h2 {
    margin: 0;
    font-size: 1.8rem;
  }

  .results-info {
    color: var(--text-light);
    font-size: 0.9rem;
  }

  .load-more-section {
    display: flex;
    justify-content: center;
    padding: 40px 0;
  }

  .load-more-btn {
    font-size: 18px;
  }

  /* Dynamic Experience Cards (rendered via JavaScript) */
  .experiences-grid .experience-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .experiences-grid .experience-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 1024px) {
    .page-container {
      padding: 1.5rem;
    }

    .main-container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .content-header h2 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .page-container {
      padding: 1rem;
    }

    .mobile-filter-controls {
      display: flex;
    }

    .content-header {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    .content-header h2 {
      font-size: 1.3rem;
      width: 100%;
    }

    .results-info {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .page-container {
      padding: 0.75rem;
    }

    .mobile-filter-controls {
      flex-direction: column;
    }

    .mobile-filter-btn,
    .sort-select {
      width: 100%;
    }

    .content-header h2 {
      font-size: 1.1rem;
    }
  }
</style>
