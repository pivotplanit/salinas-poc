---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/About/HeroCarousel.astro";
import HistorySection from "../components/About/HistorySection.astro";
import Timeline from "../components/About/Timeline.astro";
import PeopleGrid from "../components/About/PeopleGrid.astro";
import StatsGrid from "../components/About/StatsGrid.astro";
import LocationsSection from "../components/About/LocationsSection.astro";
import ClimateCarousel from "../components/About/ClimateCarousel.astro";
import CultureGrid from "../components/About/CultureGrid.astro";
import CommitmentsGrid from "../components/About/CommitmentsGrid.astro";
import CooperativesGrid from "../components/About/CooperativesGrid.astro";
---

<BaseLayout
  title="About Salinas - HABITAT Travel"
  description="Learn about the community-driven tourism model of Salinas de Guaranda"
>
  <HeroCarousel />
  <HistorySection />
  <Timeline />
  <StatsGrid />
  <PeopleGrid />
  <LocationsSection />
  <CultureGrid />
  <CommitmentsGrid />
  <ClimateCarousel />
  <CooperativesGrid />
</BaseLayout>
