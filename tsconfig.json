{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    // "jsxImportSource": "astro/jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@assets/*": ["./src/assets/*"],
      "@configs/*": ["./src/configs/*"]
    }
  }
}
