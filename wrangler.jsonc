{
	"compatibility_date": "2026-04-11",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "salinas-poc",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "habitattraveltours.com",
			"custom_domain": true
		}
	]
}